<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- =============================================
         СКРОЛЛБАР 
    ============================================= -->
    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="6"/>
    </Style>
    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="#9B59FF44"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>
    <Style Selector="ScrollBar /template/ Thumb:pointerover">
        <Setter Property="Background" Value="#9B59FF88"/>
    </Style>

    <!-- =============================================
         NAV BUTTON — кнопка сайдбара
         Использование: Classes="NavBtn"
    ============================================= -->
    <Style Selector="Border.NavBtn">
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Border.NavBtn:pointerover">
        <Setter Property="Background" Value="#1C1C28"/>
    </Style>

    <!-- =============================================
         WINDOW BUTTON — кнопки закрыть/свернуть
         Использование: Classes="WinBtn"
    ============================================= -->
    <Style Selector="Border.WinBtn">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Border.WinBtn:pointerover">
        <Setter Property="Background" Value="#1C1C28"/>
    </Style>

    <!-- Закрыть — отдельный класс без WinBtn, полный стиль -->
    <Style Selector="Border.WinBtnClose">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Border.WinBtnClose:pointerover">
        <Setter Property="Background" Value="#1C1C28"/>
    </Style>

    <!-- =============================================
         NOTIFICATION BUTTON — кнопка уведомлений в titlebar
         Использование: Classes="NotifBtn"
    ============================================= -->
    <Style Selector="Border.NotifBtn">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.18"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.18"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.NotifBtn:pointerover">
        <Setter Property="Background" Value="#1C1C28"/>
        <Setter Property="BorderBrush" Value="#50506A"/>
        <Setter Property="BoxShadow" Value="0 0 0 1 #50506A55"/>
    </Style>
    <Style Selector="Border.NotifBtn:pressed">
        <Setter Property="Background" Value="#2A233B"/>
        <Setter Property="BorderBrush" Value="#666684"/>
        <Setter Property="BoxShadow" Value="0 0 0 1 #66668455"/>
    </Style>

    <!-- =============================================
         TAB BUTTON — вкладки под заголовком
         Использование: Classes="TabBtn"
    ============================================= -->
    <Style Selector="Border.TabBtn">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Border.TabBtn:pointerover">
        <Setter Property="Background" Value="#1C1C28"/>
    </Style>

    <!-- =============================================
         PROFILE BUTTON — кнопка профиля
         Используется в Classes="ProfileBtn"
    ============================================= -->
    <Style Selector="Border.ProfileBtn">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Border.ProfileBtn:pointerover">
        <Setter Property="Background" Value="#1A1A28"/>
    </Style>

    <!-- =============================================
         AUCTION PAGE — локальные стили вкладки аукциона
    ============================================= -->
    <Style Selector=".AuctionPriceChartPage ScrollViewer ScrollBar">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage ScrollViewer ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="#A666FF"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage ScrollViewer ScrollBar /template/ Thumb:pointerover">
        <Setter Property="Background" Value="#C786FF"/>
    </Style>

    <Style Selector=".AuctionPriceChartPage ToggleButton.CategoryToggle">
        <Setter Property="Background" Value="#1A142B"/>
        <Setter Property="BorderBrush" Value="#4D3586"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="17"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Foreground" Value="#D6D0ED"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector=".AuctionPriceChartPage ToggleButton.CategoryToggle:pointerover">
        <Setter Property="Background" Value="#211738"/>
        <Setter Property="BorderBrush" Value="#6A4AB2"/>
        <Setter Property="Foreground" Value="#EFE8FF"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage ToggleButton.CategoryToggle:checked">
        <Setter Property="Background" Value="#241A40"/>
        <Setter Property="BorderBrush" Value="#7A57C9"/>
        <Setter Property="Foreground" Value="#F6F1FF"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage ToggleButton.CategoryToggle:pressed">
        <Setter Property="Background" Value="#2C1F4B"/>
        <Setter Property="BorderBrush" Value="#8A63E3"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage ToggleButton.CategoryToggle:checked TextBlock.CategoryTitle">
        <Setter Property="Foreground" Value="#F6F1FF"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage ToggleButton.CategoryToggle.HasSelectedItem">
        <Setter Property="BorderBrush" Value="{DynamicResource BrushAppAccent}"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage TextBlock.CategoryArrow">
        <Setter Property="Text" Value="▸"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage ToggleButton.CategoryToggle:checked TextBlock.CategoryArrow">
        <Setter Property="Text" Value="▾"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage Button.CategoryItemBtn">
        <Setter Property="Background" Value="#171329"/>
        <Setter Property="BorderBrush" Value="#523790"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="17"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector=".AuctionPriceChartPage Button.CategoryItemBtn:pointerover">
        <Setter Property="Background" Value="#20193A"/>
        <Setter Property="BorderBrush" Value="#7652C5"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage Button.CategoryItemBtn:pressed">
        <Setter Property="Background" Value="#2A1F4B"/>
        <Setter Property="BorderBrush" Value="#8C67E0"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage Button.CategoryItemBtn.SelectedItem">
        <Setter Property="Background" Value="#2B1F4B"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BrushAppAccent}"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage Border.AuctionCategorySearchFrame">
        <Setter Property="Background" Value="#161123"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentGradientH}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="1"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage Border.AuctionCategorySearchFrame:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentGradientH}"/>
        <Setter Property="BorderThickness" Value="1.15"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage Border.AuctionCategorySearchFrame:focus-within">
        <Setter Property="Background" Value="#130F1F"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentGradientH}"/>
        <Setter Property="BorderThickness" Value="1.3"/>
        <Setter Property="CornerRadius" Value="14"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage TextBox.AuctionCategorySearchInner">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="13"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
        <Setter Property="Padding" Value="9,6"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage TextBox.AuctionCategorySearchInner:focus">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="13"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage TextBox.AuctionCategorySearchInner /template/ Border#border">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="13"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage TextBox.AuctionCategorySearchInner /template/ Border#borderElement">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="13"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage TextBox.AuctionCategorySearchInner:focus /template/ Border#border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="13"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage TextBox.AuctionCategorySearchInner:focus /template/ Border#borderElement">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="13"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage TextBox.AuctionCategorySearchInner:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="13"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage Button.AuctionSearchClearBtn">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="MinWidth" Value="22"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="CornerRadius" Value="11"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage Button.AuctionSearchClearBtn:pointerover">
        <Setter Property="Background" Value="#241B3B"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage Button.AuctionSearchClearBtn:pressed">
        <Setter Property="Background" Value="#30234E"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage Button.AuctionCalendarTrigger">
        <Setter Property="Background" Value="#19142A"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentGradientH}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="MinWidth" Value="146"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage Button.AuctionCalendarTrigger:pointerover">
        <Setter Property="BorderThickness" Value="1.3"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage Border.AuctionCalendarPanel">
        <Setter Property="Background" Value="#141022"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentGradientH}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="MinWidth" Value="248"/>
    </Style>
    <Style Selector="Border.AuctionCalendarPanel">
        <Setter Property="Background" Value="#141022"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentGradientH}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="MinWidth" Value="248"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage TextBlock.AuctionCalendarWeekLabel">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextMuted}"/>
        <Setter Property="FontSize" Value="10"/>
    </Style>
    <Style Selector="TextBlock.AuctionCalendarWeekLabel">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextMuted}"/>
        <Setter Property="FontSize" Value="10"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage Button.AuctionDayCell">
        <Setter Property="Background" Value="#1A142B"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentGradientH}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Height" Value="25"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage Button.AuctionDayCell:pointerover">
        <Setter Property="BorderThickness" Value="1.3"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage Button.AuctionDayCell.SelectedDayCell">
        <Setter Property="Background" Value="#2B1F4B"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentGradientH}"/>
        <Setter Property="BorderThickness" Value="1.4"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage Button.AuctionDayCell.DisabledDayCell">
        <Setter Property="Opacity" Value="0.35"/>
    </Style>
    <Style Selector=".AuctionPriceChartPage Button.AuctionDayCell.PlaceholderDayCell">
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
    </Style>
    <Style Selector="Button.AuctionDayCell">
        <Setter Property="Background" Value="#1A142B"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentGradientH}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Height" Value="25"/>
    </Style>
    <Style Selector="Button.AuctionDayCell:pointerover">
        <Setter Property="BorderThickness" Value="1.3"/>
    </Style>
    <Style Selector="Button.AuctionDayCell.SelectedDayCell">
        <Setter Property="Background" Value="#2B1F4B"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentGradientH}"/>
        <Setter Property="BorderThickness" Value="1.4"/>
    </Style>
    <Style Selector="Button.AuctionDayCell.DisabledDayCell">
        <Setter Property="Opacity" Value="0.35"/>
    </Style>
    <Style Selector="Button.AuctionDayCell.PlaceholderDayCell">
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
    </Style>

    <!-- =============================================
         CALCULATOR PAGE — локальные стили вкладки калькулятора
    ============================================= -->
    <Style Selector=".AuctionCalculatorPage Border.CalculatorPanel">
        <Setter Property="Background" Value="{DynamicResource BrushBgDeep}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="22"/>
        <Setter Property="Padding" Value="13"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage TextBox.CalculatorInput">
        <Setter Property="Background" Value="#181424"/>
        <Setter Property="BorderBrush" Value="#4A3A73"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
        <Setter Property="Padding" Value="10,7"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage TextBox.CalculatorInput:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource BrushAppAccent}"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage ComboBox.CalculatorCombo">
        <Setter Property="Background" Value="#181424"/>
        <Setter Property="BorderBrush" Value="#4A3A73"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
        <Setter Property="Padding" Value="8,6"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage ComboBox.CalculatorCombo:pointerover">
        <Setter Property="BorderBrush" Value="#7352B7"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage ComboBox.CalculatorCombo:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource BrushAppAccent}"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage ComboBox.CalculatorCombo ComboBoxItem">
        <Setter Property="Background" Value="#171425"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage ComboBox.CalculatorCombo ComboBoxItem:pointerover">
        <Setter Property="Background" Value="#241C3B"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage ComboBox.CalculatorCombo ComboBoxItem:selected">
        <Setter Property="Background" Value="#2D2248"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage Border.CalculatorMetricCard">
        <Setter Property="Background" Value="#14111F"/>
        <Setter Property="BorderBrush" Value="#3D3450"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="10"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage TextBlock.CalculatorMetricTitle">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage TextBlock.CalculatorMetricValue">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage TextBlock.CalculatorMetricValueBig">
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage Border.CalculatorProfitBar">
        <Setter Property="Background" Value="#161228"/>
        <Setter Property="BorderBrush" Value="#564488"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="10,8"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage Button.CalculatorQtyButton">
        <Setter Property="Background" Value="#201A33"/>
        <Setter Property="BorderBrush" Value="#5C478E"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage Button.CalculatorQtyButton:pointerover">
        <Setter Property="Background" Value="#2A2144"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BrushAppAccent}"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage Button.CalculatorPresetButton">
        <Setter Property="Background" Value="#1A1629"/>
        <Setter Property="BorderBrush" Value="#4C3D74"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="9"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}"/>
        <Setter Property="Padding" Value="7,3"/>
        <Setter Property="Margin" Value="0,0,5,5"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage Button.CalculatorPresetButton:pointerover">
        <Setter Property="Background" Value="#251D3C"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BrushAppAccent}"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage Button.CalculatorActionButton">
        <Setter Property="Background" Value="{DynamicResource AccentGradientH}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Foreground" Value="#F8F4FF"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="10,7"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage Button.CalculatorActionButton:pointerover">
        <Setter Property="Opacity" Value="0.9"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage Button.CalculatorActionButton:pressed">
        <Setter Property="Opacity" Value="0.8"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage Border.CalculatorOverlayBackdrop">
        <Setter Property="Background" Value="#9A05040C"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage Border.CalculatorOverlayPanel">
        <Setter Property="Background" Value="#0B0A12"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentGradientH}"/>
        <Setter Property="BorderThickness" Value="1.1"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="BoxShadow" Value="0 20 48 #00000066"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage Button.CalculatorOverlayCloseButton">
        <Setter Property="Background" Value="#201835"/>
        <Setter Property="BorderBrush" Value="#6644AE"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Foreground" Value="#F3EEFF"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage Button.CalculatorOverlayCloseButton:pointerover">
        <Setter Property="Background" Value="#2A2144"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BrushAppAccent}"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage Button.CalculatorLotButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="16"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage Button.CalculatorLotButton:pointerover Border.CalculatorLotCard">
        <Setter Property="Background" Value="#1B152A"/>
        <Setter Property="BorderBrush" Value="#7A57C9"/>
        <Setter Property="BorderThickness" Value="1.3"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage Button.CalculatorLotButton:pressed Border.CalculatorLotCard">
        <Setter Property="Background" Value="#211935"/>
        <Setter Property="BorderBrush" Value="#8C67E0"/>
    </Style>
    <Style Selector=".AuctionCalculatorPage Border.CalculatorLotCard">
        <Setter Property="Background" Value="#15111F"/>
        <Setter Property="BorderBrush" Value="#4A3382"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="BoxShadow" Value="0 8 18 #0000002E"/>
    </Style>

    <!-- ListBox без фона -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

</Styles>
