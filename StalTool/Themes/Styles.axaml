<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- =============================================
         СКРОЛЛБАР 
    ============================================= -->
    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="8"/>
    </Style>
    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="#9F6BFFAA"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <Style Selector="ScrollBar /template/ Thumb:pointerover">
        <Setter Property="Background" Value="#B181FF"/>
    </Style>

    <!-- =============================================
         NAV BUTTON — кнопка сайдбара
         Использование: Classes="NavBtn"
    ============================================= -->
    <Style Selector="Border.NavBtn">
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Border.NavBtn:pointerover">
        <Setter Property="Background" Value="#1C1C28"/>
    </Style>

    <!-- =============================================
         WINDOW BUTTON — кнопки закрыть/свернуть
         Использование: Classes="WinBtn"
    ============================================= -->
    <Style Selector="Border.WinBtn">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Border.WinBtn:pointerover">
        <Setter Property="Background" Value="#1C1C28"/>
    </Style>

    <!-- Закрыть — отдельный класс без WinBtn, полный стиль -->
    <Style Selector="Border.WinBtnClose">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Border.WinBtnClose:pointerover">
        <Setter Property="Background" Value="#1C1C28"/>
    </Style>

    <!-- =============================================
         NOTIFICATION BUTTON — кнопка уведомлений в titlebar
         Использование: Classes="NotifBtn"
    ============================================= -->
    <Style Selector="Border.NotifBtn">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.18"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.18"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.NotifBtn:pointerover">
        <Setter Property="Background" Value="#1C1C28"/>
        <Setter Property="BorderBrush" Value="#50506A"/>
        <Setter Property="BoxShadow" Value="0 0 0 1 #50506A55"/>
    </Style>
    <Style Selector="Border.NotifBtn:pressed">
        <Setter Property="Background" Value="#2A233B"/>
        <Setter Property="BorderBrush" Value="#666684"/>
        <Setter Property="BoxShadow" Value="0 0 0 1 #66668455"/>
    </Style>

    <!-- =============================================
         TAB BUTTON — вкладки под заголовком
         Использование: Classes="TabBtn"
    ============================================= -->
    <Style Selector="Border.TabBtn">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Border.TabBtn:pointerover">
        <Setter Property="Background" Value="#1C1C28"/>
    </Style>

    <!-- =============================================
         PROFILE BUTTON — кнопка профиля
         Используется в Classes="ProfileBtn"
    ============================================= -->
    <Style Selector="Border.ProfileBtn">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Border.ProfileBtn:pointerover">
        <Setter Property="Background" Value="#1A1A28"/>
    </Style>

    <!-- ListBox без фона -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

</Styles>
