<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:StalTool.ViewModels"
        x:Class="StalTool.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Width="760"
        Height="500"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Title="StalTool | Вход">
    <Border Background="#CC0D0D12">
        <Grid>
            <Ellipse Width="500"
                     Height="500"
                     Fill="#229B59FF"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Margin="-240,-250,0,0"/>
            <Ellipse Width="560"
                     Height="560"
                     Fill="#22E040C8"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Margin="0,0,-240,-280"/>

            <Border Margin="28"
                    Background="{StaticResource BannerGradient}"
                    BorderBrush="#7A49E8"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="24">
                <Grid ColumnDefinitions="1.05*,1*"
                      ColumnSpacing="18">
                    <Border Grid.Column="0"
                            Background="#120D1C"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="20">
                        <StackPanel Spacing="10"
                                    VerticalAlignment="Center">
                            <TextBlock Text="StalTool"
                                       FontSize="36"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BrushTextPrimary}"/>
                            <TextBlock Text="Авторизация"
                                       FontSize="16"
                                       Foreground="{StaticResource BrushTextSecondary}"/>
                            <TextBlock Text="Макет входа в стиле основного интерфейса"
                                       Margin="0,8,0,0"
                                       FontSize="13"
                                       Foreground="{StaticResource BrushTextMuted}"/>
                            <Border Margin="0,16,0,0"
                                    Background="#1B132A"
                                    BorderBrush="#6A3FD5"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10,8">
                                <TextBlock Text="После нажатия «Войти» откроется основное окно"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           FontSize="12"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="#0F0E16"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="18">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*"
                              RowSpacing="8">
                            <TextBlock Text="Логин"
                                       Foreground="{StaticResource BrushTextSecondary}"/>
                            <TextBox Grid.Row="1"
                                     Text="{Binding Username}"
                                     Watermark="Введите логин"
                                     Background="#181523"
                                     BorderBrush="#6A3FD5"
                                     BorderThickness="1"
                                     Foreground="{StaticResource BrushTextPrimary}"
                                     Padding="10,8"/>

                            <TextBlock Grid.Row="2"
                                       Margin="0,8,0,0"
                                       Text="Пароль"
                                       Foreground="{StaticResource BrushTextSecondary}"/>
                            <TextBox Grid.Row="3"
                                     Text="{Binding Password}"
                                     Watermark="Введите пароль"
                                     PasswordChar="●"
                                     Background="#181523"
                                     BorderBrush="#6A3FD5"
                                     BorderThickness="1"
                                     Foreground="{StaticResource BrushTextPrimary}"
                                     Padding="10,8"/>

                    <Button Grid.Row="5"
                            Height="44"
                            Margin="0,10,0,0"
                            Content="Войти"
                            Command="{Binding SignInCommand}"
                            Background="{StaticResource AccentGradientH}"
                            BorderBrush="#A868FF"
                            BorderThickness="1"
                            CornerRadius="10"
                            Foreground="{StaticResource BrushTextPrimary}"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            MinWidth="0"
                            VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
