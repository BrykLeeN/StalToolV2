<UserControl
    x:Class="StalTool.Views.Pages.AuctionPriceChartPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:StalTool.ViewModels.Auction.Sections"
    x:Name="Root"
    x:DataType="vm:AuctionPriceChartViewModel">

    <Grid Margin="18"
          ColumnDefinitions="280,1.55*,1.25*"
          RowDefinitions="1.35*,0.85*"
          ColumnSpacing="16"
          RowSpacing="16">

        <Border Grid.Column="0"
                Grid.RowSpan="2"
                Background="#100D1B"
                BorderBrush="#251A3E"
                BorderThickness="1"
                CornerRadius="22"
                Padding="14">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="Категории"
                           Foreground="#F3EEFF"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <ScrollViewer Grid.Row="1"
                              Padding="0,0,6,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander IsExpanded="True"
                                          Margin="0,0,0,10"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          BorderThickness="0"
                                          CornerRadius="0"
                                          Padding="0">
                                    <Expander.Header>
                                        <Border Background="#0DFFFFFF"
                                                BorderBrush="#2A2146"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="10,8"
                                                BoxShadow="0 6 16 #00000030">
                                            <TextBlock Text="{Binding CategoryName}"
                                                       Foreground="#CEC7E4"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </Expander.Header>
                                    <ItemsControl ItemsSource="{Binding Items}"
                                                  Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{ReflectionBinding DataContext.SelectItemCommand, ElementName=Root}"
                                                        CommandParameter="{Binding .}"
                                                        Background="#0DFFFFFF"
                                                        BorderBrush="#2E2450"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="12,10"
                                                        Margin="0,0,0,8"
                                                        HorizontalContentAlignment="Stretch">
                                                    <Grid ColumnDefinitions="*,Auto"
                                                          ColumnSpacing="8">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="#ECE8F8"
                                                                   FontSize="13"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <Border Grid.Column="1"
                                                                Background="#231A3E"
                                                                CornerRadius="8"
                                                                Padding="7,2"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Rank}"
                                                                       Foreground="#C9A7FF"
                                                                       FontSize="10"/>
                                                        </Border>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="#100D1B"
                BorderBrush="#251A3E"
                BorderThickness="1"
                CornerRadius="22"
                Padding="18">
            <Grid RowDefinitions="Auto,*,Auto"
                  RowSpacing="8">
                <StackPanel Grid.Row="0"
                            Spacing="2"
                            HorizontalAlignment="Left">
                    <TextBlock Text="История цены"
                               Foreground="#8D86A6"
                               FontSize="14"
                               HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding SelectedItemName}"
                               Foreground="#FFFFFF"
                               FontSize="38"
                               FontWeight="Bold"
                               HorizontalAlignment="Left"/>
                </StackPanel>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding ChartBars}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="360"
                                  VerticalAlignment="Bottom">
                                <Border Width="28"
                                        Height="{Binding Height}"
                                        Background="{Binding Fill}"
                                        CornerRadius="12,12,4,4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding ChartBars}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}"
                                       HorizontalAlignment="Center"
                                       Foreground="#787194"
                                       FontSize="11"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="1"
                Background="#100D1B"
                BorderBrush="#251A3E"
                BorderThickness="1"
                CornerRadius="20"
                Padding="14">
            <Grid RowDefinitions="Auto,Auto,Auto,*"
                  ColumnDefinitions="1*,1*"
                  RowSpacing="12"
                  ColumnSpacing="12">
                <Border Grid.Row="0"
                        Grid.Column="0"
                        Background="#0DFFFFFF"
                        BorderBrush="#30224F"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12,10"
                        BoxShadow="0 8 18 #0000002E">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Текущая"
                                   Foreground="#9E96BA"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding CurrentPriceText}"
                                   Foreground="#F2EDFF"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0"
                        Grid.Column="1"
                        Background="#0DFFFFFF"
                        BorderBrush="#30224F"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12,10"
                        BoxShadow="0 8 18 #0000002E">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Минимум"
                                   Foreground="#9E96BA"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding MinPriceText}"
                                   Foreground="#F2EDFF"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Background="#0DFFFFFF"
                        BorderBrush="#30224F"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12,10"
                        BoxShadow="0 8 18 #0000002E">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Средняя"
                                   Foreground="#9E96BA"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding AvgPriceText}"
                                   Foreground="#F2EDFF"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="1"
                        Background="#0DFFFFFF"
                        BorderBrush="#30224F"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12,10"
                        BoxShadow="0 8 18 #0000002E">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Максимум"
                                   Foreground="#9E96BA"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding MaxPriceText}"
                                   Foreground="#F2EDFF"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Background="#0DFFFFFF"
                        BorderBrush="#30224F"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12,10"
                        BoxShadow="0 8 18 #0000002E">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Тренд"
                                       Foreground="#9E96BA"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding TrendText}"
                                       Foreground="#E0D9F8"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding TrendDisplayText}"
                                   Foreground="{Binding TrendBrush}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="3"
                      Grid.ColumnSpan="2"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="10"
                      VerticalAlignment="Center">
                    <TextBlock Text="{Binding RecommendationText}"
                               Foreground="#8E86AB"
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <ItemsControl Grid.Column="1"
                                  ItemsSource="{Binding Periods}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{ReflectionBinding DataContext.SetPeriodCommand, ElementName=Root}"
                                        CommandParameter="{Binding .}"
                                        Content="{Binding .}"
                                        MinWidth="54"
                                        Height="34"
                                        Padding="12,0"
                                        CornerRadius="10"
                                        Background="#171327"
                                        BorderBrush="#31244F"
                                        BorderThickness="1"
                                        Foreground="#E6E1F7"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Grid.Row="1"
                Background="#100D1B"
                BorderBrush="#251A3E"
                BorderThickness="1"
                CornerRadius="20"
                Padding="14">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="Активные лоты"
                           Foreground="#F3EEFF"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>
                <ScrollViewer Grid.Row="1"
                              Padding="0,0,6,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ActiveLots}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0DFFFFFF"
                                        BorderBrush="#30224F"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="12"
                                        Margin="0,0,0,10"
                                        BoxShadow="0 8 18 #0000002E">
                                    <Grid ColumnDefinitions="48,*,Auto"
                                          RowDefinitions="Auto,Auto,Auto"
                                          ColumnSpacing="10">
                                        <Border Grid.RowSpan="3"
                                                Width="48"
                                                Height="48"
                                                CornerRadius="14"
                                                Background="#241B3E"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DisplayName}"
                                                   Foreground="#F5F2FF"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding CurrentPrice, StringFormat={}{0:N0} ₽}"
                                                   Foreground="#FFFFFF"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Text="{Binding PriceStatus}"
                                                   Foreground="#A98BFF"
                                                   FontSize="12"/>
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="2"
                                                   Text="{Binding BuyoutPrice, StringFormat=Выкуп {0:N0} ₽}"
                                                   Foreground="#8C86A5"
                                                   FontSize="12"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="1"
                                                   Text="{Binding StartPrice, StringFormat=Старт {0:N0} ₽}"
                                                   Foreground="#76708E"
                                                   FontSize="12"/>
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="2"
                                                   Text="{Binding EndTime, StringFormat=До {0:dd.MM HH:mm}}"
                                                   Foreground="#76708E"
                                                   FontSize="12"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
