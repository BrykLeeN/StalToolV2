<UserControl
    x:Class="StalTool.Views.Pages.AuctionPriceChartPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:StalTool.Converters"
    xmlns:vm="using:StalTool.ViewModels.Auction.Sections"
    x:Name="Root"
    Classes="AuctionPriceChartPage"
    x:DataType="vm:AuctionPriceChartViewModel">
    <UserControl.Resources>
        <conv:IconPathToBitmapConverter x:Key="IconPathToBitmapConverter"/>
        <conv:RankToBrushConverter x:Key="RankToBrushConverter"/>
        <conv:RankToLabelConverter x:Key="RankToLabelConverter"/>
        <conv:StringNotEmptyToBoolConverter x:Key="StringNotEmptyToBoolConverter"/>
    </UserControl.Resources>

    <Grid Margin="14"
          Background="Transparent"
          Focusable="True"
          PointerPressed="OnRootPointerPressed"
          ColumnDefinitions="280,1.55*,1.25*"
          RowDefinitions="1.35*,0.85*"
          ColumnSpacing="12"
          RowSpacing="12">
        <Border Grid.Column="0"
                Grid.RowSpan="2"
                Background="{DynamicResource BrushBgDeep}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="22"
                Padding="14">
            <Grid RowDefinitions="Auto,Auto,*"
                  RowSpacing="10">
                <TextBlock Grid.Row="0"
                           Text="Категории"
                           Foreground="{DynamicResource BrushTextPrimary}"
                           FontSize="18"
                           FontWeight="SemiBold"/>

                <Border Grid.Row="1"
                        Classes="AuctionCategorySearchFrame"
                        HorizontalAlignment="Stretch">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="6">
                        <TextBox Grid.Column="0"
                                 Text="{Binding SearchText}"
                                 Watermark="Поиск предмета..."
                                 Classes="AuctionCategorySearchInner"
                                 HorizontalAlignment="Stretch"/>
                        <Button Grid.Column="1"
                                Command="{Binding ClearSearchCommand}"
                                IsVisible="{Binding SearchText, Converter={StaticResource StringNotEmptyToBoolConverter}}"
                                Classes="AuctionSearchClearBtn"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="×"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,-1,0,0"/>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2"
                              Padding="0,0,6,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,10"
                                            Spacing="8">
                                    <ToggleButton x:Name="CategoryToggle"
                                                  Classes="CategoryToggle"
                                                  Classes.HasSelectedItem="{Binding HasSelectedItem}"
                                                  IsChecked="{Binding IsExpanded}"
                                                  Focusable="False">
                                        <Grid ColumnDefinitions="Auto,*,Auto"
                                              ColumnSpacing="8">
                                            <Border Width="8"
                                                    Height="8"
                                                    CornerRadius="8"
                                                    Background="{DynamicResource BrushAppAccent}"
                                                    IsVisible="{Binding ShowCollapsedSelectedIndicator}"
                                                    VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding CategoryName}"
                                                       Grid.Column="1"
                                                       Classes="CategoryTitle"
                                                       Foreground="{DynamicResource BrushTextSecondary}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2"
                                                       Classes="CategoryArrow"
                                                       Text="▸"
                                                       Foreground="{DynamicResource BrushTextPrimary}"
                                                       FontSize="18"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </ToggleButton>

                                    <ItemsControl ItemsSource="{Binding FilteredItems}"
                                                  Margin="8,0,8,0"
                                                  IsVisible="{Binding IsExpanded}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Spacing="6">
                                                    <Button Command="{ReflectionBinding DataContext.ToggleOrSelectItemCommand, ElementName=Root}"
                                                            Classes="CategoryItemBtn"
                                                            Classes.SelectedItem="{Binding IsSelected}"
                                                            CommandParameter="{Binding .}"
                                                            PointerPressed="OnCategoryItemPointerPressed"
                                                            Margin="0,0,0,2"
                                                            HorizontalContentAlignment="Stretch">
                                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                                              ColumnSpacing="8">
                                                            <Border Width="26"
                                                                    Height="26"
                                                                    CornerRadius="8"
                                                                    Background="#1F1635"
                                                                    BorderBrush="#5A3D99"
                                                                    BorderThickness="1"
                                                                    VerticalAlignment="Center">
                                                                <Image Source="{Binding IconPath, Converter={StaticResource IconPathToBitmapConverter}}"
                                                                       Stretch="UniformToFill"
                                                                       Width="20"
                                                                       Height="20"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       Grid.Column="1"
                                                                       Foreground="{DynamicResource BrushTextPrimary}"
                                                                       FontSize="13"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <Border Grid.Column="2"
                                                                    IsVisible="{Binding Rank, Converter={StaticResource StringNotEmptyToBoolConverter}}"
                                                                    Background="{Binding Rank, Converter={StaticResource RankToBrushConverter}, ConverterParameter=background}"
                                                                    BorderBrush="{Binding Rank, Converter={StaticResource RankToBrushConverter}, ConverterParameter=border}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    Padding="7,2"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Rank, Converter={StaticResource RankToLabelConverter}}"
                                                                           Foreground="{Binding Rank, Converter={StaticResource RankToBrushConverter}}"
                                                                           FontSize="10"/>
                                                            </Border>
                                                            <TextBlock Grid.Column="3"
                                                                       Text="⌄"
                                                                       IsVisible="{Binding HasQualityVariants}"
                                                                       Foreground="{DynamicResource BrushTextSecondary}"
                                                                       FontSize="14"
                                                                       VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Button>

                                                    <ItemsControl ItemsSource="{Binding VisibleQualityVariants}"
                                                                  Margin="14,0,0,4"
                                                                  IsVisible="{Binding IsExpanded}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Button Command="{ReflectionBinding DataContext.SelectItemCommand, ElementName=Root}"
                                                                        Classes="CategoryItemBtn"
                                                                        Classes.SelectedItem="{Binding IsSelected}"
                                                                        CommandParameter="{Binding .}"
                                                                        PointerPressed="OnCategoryItemPointerPressed"
                                                                        Margin="0,0,0,6"
                                                                        HorizontalContentAlignment="Stretch">
                                                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                                                          ColumnSpacing="8">
                                                                        <Border Width="22"
                                                                                Height="22"
                                                                                CornerRadius="7"
                                                                                Background="#1F1635"
                                                                                BorderBrush="#5A3D99"
                                                                                BorderThickness="1"
                                                                                VerticalAlignment="Center">
                                                                            <Image Source="{Binding IconPath, Converter={StaticResource IconPathToBitmapConverter}}"
                                                                                   Stretch="UniformToFill"
                                                                                   Width="16"
                                                                                   Height="16"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <TextBlock Text="{Binding DisplayName}"
                                                                                   Grid.Column="1"
                                                                                   Foreground="{DynamicResource BrushTextPrimary}"
                                                                                   FontSize="12"
                                                                                   VerticalAlignment="Center"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                        <Border Grid.Column="2"
                                                                                Background="{Binding Rank, Converter={StaticResource RankToBrushConverter}, ConverterParameter=background}"
                                                                                BorderBrush="{Binding Rank, Converter={StaticResource RankToBrushConverter}, ConverterParameter=border}"
                                                                                BorderThickness="1"
                                                                                CornerRadius="8"
                                                                                Padding="7,2"
                                                                                VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Rank, Converter={StaticResource RankToLabelConverter}}"
                                                                                       Foreground="{Binding Rank, Converter={StaticResource RankToBrushConverter}}"
                                                                                       FontSize="10"/>
                                                                        </Border>
                                                                    </Grid>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="{DynamicResource BrushBgDeep}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="22"
                Padding="18">
            <Grid RowDefinitions="Auto,*,Auto"
                  RowSpacing="8">
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <StackPanel Spacing="2"
                                HorizontalAlignment="Left">
                        <TextBlock Text="История цены"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   FontSize="14"
                                   HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding SelectedItemName}"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   FontSize="38"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Left"/>
                    </StackPanel>
                    <Grid Grid.Column="1"
                          VerticalAlignment="Center">
                        <Button x:Name="EnhancementFilterButton"
                                Classes="AuctionCalendarTrigger"
                                Content="{Binding SelectedEnhancementFilterText}"
                                Command="{Binding ToggleEnhancementFilterCommand}"
                                MinWidth="132"
                                HorizontalAlignment="Right"/>
                        <Popup IsOpen="{Binding IsEnhancementFilterOpen, Mode=TwoWay}"
                               IsLightDismissEnabled="True"
                               OverlayDismissEventPassThrough="True"
                               ShouldUseOverlayLayer="True"
                               Topmost="True"
                               Placement="BottomEdgeAlignedRight"
                               PlacementTarget="{Binding #EnhancementFilterButton}">
                            <Border Classes="AuctionCalendarPanel"
                                    MinWidth="132">
                                <StackPanel Spacing="4">
                                    <ItemsControl ItemsSource="{Binding EnhancementFilters}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Classes="AuctionDayCell"
                                                        Classes.SelectedDayCell="{Binding IsSelected}"
                                                        Content="{Binding Title}"
                                                        Command="{ReflectionBinding DataContext.SelectEnhancementFilterCommand, ElementName=Root}"
                                                        CommandParameter="{Binding .}"
                                                        HorizontalContentAlignment="Center"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>

                <Border Grid.Row="1"
                        Background="#0A090F"
                        BorderBrush="#251A3E"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="10,8,10,8">
                    <Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Disabled"
                                      HorizontalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ChartBars}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="6"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid RowDefinitions="Auto,252,Auto"
                                              RowSpacing="3"
                                              Width="26"
                                              VerticalAlignment="Bottom">
                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding BarMetaText}"
                                                       IsVisible="{Binding HasMetaText}"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#B8ADDE"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"/>
                                            <Button Grid.Row="1"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="0"
                                                    Command="{ReflectionBinding DataContext.ToggleChartBarSelectionCommand, ElementName=Root}"
                                                    CommandParameter="{Binding .}">
                                                <ToolTip.Tip>
                                                    <TextBlock Text="{Binding ValueText}"/>
                                                </ToolTip.Tip>
                                                <Grid Height="252"
                                                      Width="22">
                                                    <Border Width="18"
                                                            Height="{Binding Height}"
                                                            Background="{Binding Fill}"
                                                            CornerRadius="10,10,4,4"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Bottom"/>
                                                </Grid>
                                            </Button>
                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding Label}"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource BrushTextMuted}"
                                                       FontSize="10"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Grid Grid.Row="2"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{Binding SelectedSaleText}"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding SelectedAverageText}"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Classes="AuctionCalendarTrigger"
                            Content="Сбросить выбор"
                            Command="{Binding ClearSaleSelectionCommand}"
                            MinWidth="130"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"/>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="1"
                Background="{DynamicResource BrushBgDeep}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="20"
                Padding="14">
            <Grid RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="10">
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="10"
                      VerticalAlignment="Center">
                    <TextBlock Text="{Binding RecommendationText}"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <Grid Grid.Column="1">
                        <Button x:Name="CalendarToggleButton"
                                Classes="AuctionCalendarTrigger"
                                Content="{Binding SelectedDayText}"
                                Command="{Binding ToggleCalendarCommand}"
                                HorizontalAlignment="Right"/>
                        <Popup IsOpen="{Binding IsCalendarOpen, Mode=TwoWay}"
                               IsLightDismissEnabled="True"
                               OverlayDismissEventPassThrough="True"
                               ShouldUseOverlayLayer="True"
                               Topmost="True"
                               Placement="BottomEdgeAlignedRight"
                               PlacementTarget="{Binding #CalendarToggleButton}"
                               VerticalOffset="8">
                            <Border Classes="AuctionCalendarPanel">
                                <StackPanel Spacing="6">
                                    <UniformGrid Columns="7">
                                        <TextBlock Text="Пн" Classes="AuctionCalendarWeekLabel"/>
                                        <TextBlock Text="Вт" Classes="AuctionCalendarWeekLabel"/>
                                        <TextBlock Text="Ср" Classes="AuctionCalendarWeekLabel"/>
                                        <TextBlock Text="Чт" Classes="AuctionCalendarWeekLabel"/>
                                        <TextBlock Text="Пт" Classes="AuctionCalendarWeekLabel"/>
                                        <TextBlock Text="Сб" Classes="AuctionCalendarWeekLabel"/>
                                        <TextBlock Text="Вс" Classes="AuctionCalendarWeekLabel"/>
                                    </UniformGrid>
                                    <ItemsControl ItemsSource="{Binding CalendarDays}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="7"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Classes="AuctionDayCell"
                                                        Classes.SelectedDayCell="{Binding IsSelected}"
                                                        Classes.DisabledDayCell="{Binding IsUnavailable}"
                                                        Classes.PlaceholderDayCell="{Binding IsPlaceholder}"
                                                        IsEnabled="{Binding IsAvailable}"
                                                        Command="{ReflectionBinding DataContext.SelectDayCommand, ElementName=Root}"
                                                        CommandParameter="{Binding Date}"
                                                        Content="{Binding DayNumber}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>

                <Grid Grid.Row="1"
                      ColumnDefinitions="1*,1*,1*"
                      ColumnSpacing="10">
                    <Border Grid.Column="0"
                            Background="#0CFFFFFF"
                            BorderBrush="#4A3382"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12,10"
                            BoxShadow="0 10 20 #00000033">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Текущая"
                                       Foreground="#A9A0CA"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding CurrentPriceText}"
                                       Foreground="#FFFFFF"
                                       FontSize="18"
                                       TextWrapping="Wrap"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="#0CFFFFFF"
                            BorderBrush="#4A3382"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12,10"
                            BoxShadow="0 10 20 #00000033">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Минимум"
                                       Foreground="#A9A0CA"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding MinPriceText}"
                                       Foreground="#FFFFFF"
                                       FontSize="18"
                                       TextWrapping="Wrap"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#0CFFFFFF"
                            BorderBrush="#4A3382"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12,10"
                            BoxShadow="0 10 20 #00000033">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Средняя"
                                       Foreground="#A9A0CA"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding AvgPriceText}"
                                       Foreground="#FFFFFF"
                                       FontSize="18"
                                       TextWrapping="Wrap"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2"
                      ColumnDefinitions="1*,1*"
                      ColumnSpacing="10">
                    <Border Grid.Column="0"
                            Background="#0CFFFFFF"
                            BorderBrush="#4A3382"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12,10"
                            BoxShadow="0 10 20 #00000033">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Максимум"
                                       Foreground="#A9A0CA"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding MaxPriceText}"
                                       Foreground="#FFFFFF"
                                       FontSize="18"
                                       TextWrapping="Wrap"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="#0CFFFFFF"
                            BorderBrush="#4A3382"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12,10"
                            BoxShadow="0 10 20 #00000033">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Тренд"
                                           Foreground="#A9A0CA"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding TrendText}"
                                           Foreground="#FFFFFF"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding TrendDisplayText}"
                                       Foreground="{Binding TrendBrush}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Grid.Row="1"
                Background="#0A090F"
                BorderBrush="#251A3E"
                BorderThickness="1"
                CornerRadius="20"
                Padding="14">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="Активные лоты"
                           Foreground="#F3EEFF"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>
                <ScrollViewer Grid.Row="1"
                              Padding="0,0,6,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ActiveLots}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#15111F"
                                        BorderBrush="#4A3382"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="12"
                                        Margin="0,0,0,10"
                                        BoxShadow="0 8 18 #0000002E">
                                    <Grid ColumnDefinitions="48,*,Auto"
                                          RowDefinitions="Auto,Auto,Auto"
                                          ColumnSpacing="10">
                                        <Border Grid.RowSpan="3"
                                                Width="48"
                                                Height="48"
                                                CornerRadius="14"
                                                Background="#241B3E"
                                                BorderBrush="#5A3D99"
                                                BorderThickness="1"
                                                ClipToBounds="True">
                                            <Grid>
                                                <Image Source="{Binding IconPath, Converter={StaticResource IconPathToBitmapConverter}}"
                                                       Stretch="UniformToFill"
                                                       Width="48"
                                                       Height="48"/>
                                                <Border HorizontalAlignment="Right"
                                                        VerticalAlignment="Bottom"
                                                        Margin="0,0,2,2"
                                                        IsVisible="{Binding ShowAmountBadge}"
                                                        Background="#CC11111A"
                                                        BorderBrush="#8B6BCA"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="4,1">
                                                    <TextBlock Text="{Binding Amount}"
                                                               Foreground="#F5F2FF"
                                                               FontSize="10"
                                                               FontWeight="Bold"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DisplayName}"
                                                   Foreground="#F5F2FF"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding CurrentPrice, StringFormat={}{0:N0} ₽}"
                                                   Foreground="#FFFFFF"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Text="{Binding PriceStatus}"
                                                   Foreground="#A98BFF"
                                                   FontSize="12"/>
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="2"
                                                   Text="{Binding BuyoutPrice, StringFormat=Выкуп {0:N0} ₽}"
                                                   Foreground="#8C86A5"
                                                   FontSize="12"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="1"
                                                   Text="{Binding StartPrice, StringFormat=Старт {0:N0} ₽}"
                                                   Foreground="#76708E"
                                                   FontSize="12"/>
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="2"
                                                   Text="{Binding EndTime, StringFormat=До {0:dd.MM HH:mm}}"
                                                   Foreground="#76708E"
                                                   FontSize="12"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
