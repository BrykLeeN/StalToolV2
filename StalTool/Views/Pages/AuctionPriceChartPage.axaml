<UserControl
    x:Class="StalTool.Views.Pages.AuctionPriceChartPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:StalTool.Converters"
    xmlns:vm="using:StalTool.ViewModels.Auction.Sections"
    x:Name="Root"
    Classes="AuctionPriceChartPage"
    x:DataType="vm:AuctionPriceChartViewModel">
    <UserControl.Resources>
        <conv:IconPathToBitmapConverter x:Key="IconPathToBitmapConverter"/>
    </UserControl.Resources>

    <Grid Margin="14"
          Background="Transparent"
          Focusable="True"
          PointerPressed="OnRootPointerPressed"
          ColumnDefinitions="280,1.55*,1.25*"
          RowDefinitions="1.35*,0.85*"
          ColumnSpacing="12"
          RowSpacing="12">
        <Border Grid.Column="0"
                Grid.RowSpan="2"
                Background="{DynamicResource BrushBgDeep}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="22"
                Padding="14">
            <Grid RowDefinitions="Auto,Auto,*"
                  RowSpacing="10">
                <TextBlock Grid.Row="0"
                           Text="Категории"
                           Foreground="{DynamicResource BrushTextPrimary}"
                           FontSize="18"
                           FontWeight="SemiBold"/>

                <Border Grid.Row="1"
                        Classes="AuctionCategorySearchFrame"
                        HorizontalAlignment="Stretch">
                    <TextBox Text="{Binding SearchText}"
                             Watermark="Поиск предмета..."
                             Classes="AuctionCategorySearchInner"
                             HorizontalAlignment="Stretch"/>
                </Border>

                <ScrollViewer Grid.Row="2"
                              Padding="0,0,6,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,10"
                                            Spacing="8">
                                    <ToggleButton x:Name="CategoryToggle"
                                                  Classes="CategoryToggle"
                                                  Classes.HasSelectedItem="{Binding HasSelectedItem}"
                                                  IsChecked="{Binding IsExpanded}"
                                                  Focusable="False">
                                        <Grid ColumnDefinitions="Auto,*,Auto"
                                              ColumnSpacing="8">
                                            <Border Width="8"
                                                    Height="8"
                                                    CornerRadius="8"
                                                    Background="{DynamicResource BrushAppAccent}"
                                                    IsVisible="{Binding ShowCollapsedSelectedIndicator}"
                                                    VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding CategoryName}"
                                                       Grid.Column="1"
                                                       Classes="CategoryTitle"
                                                       Foreground="{DynamicResource BrushTextSecondary}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2"
                                                       Classes="CategoryArrow"
                                                       Text="⌄"
                                                       Foreground="{DynamicResource BrushTextPrimary}"
                                                       FontSize="18"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </ToggleButton>

                                    <ItemsControl ItemsSource="{Binding FilteredItems}"
                                                  Margin="8,0,8,0"
                                                  IsVisible="{Binding IsExpanded}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{ReflectionBinding DataContext.SelectItemCommand, ElementName=Root}"
                                                        Classes="CategoryItemBtn"
                                                        Classes.SelectedItem="{Binding IsSelected}"
                                                        CommandParameter="{Binding .}"
                                                        Margin="0,0,0,8"
                                                        HorizontalContentAlignment="Stretch">
                                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                                          ColumnSpacing="8">
                                                        <Border Width="26"
                                                                Height="26"
                                                                CornerRadius="8"
                                                                Background="#1F1635"
                                                                BorderBrush="#5A3D99"
                                                                BorderThickness="1"
                                                                VerticalAlignment="Center">
                                                            <Image Source="{Binding IconPath, Converter={StaticResource IconPathToBitmapConverter}}"
                                                                   Stretch="UniformToFill"
                                                                   Width="20"
                                                                   Height="20"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Grid.Column="1"
                                                                   Foreground="{DynamicResource BrushTextPrimary}"
                                                                   FontSize="13"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <Border Grid.Column="2"
                                                                Background="#261B42"
                                                                BorderBrush="#5A3D99"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Padding="7,2"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Rank}"
                                                                       Foreground="{DynamicResource BrushTextPrimary}"
                                                                       FontSize="10"/>
                                                        </Border>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="{DynamicResource BrushBgDeep}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="22"
                Padding="18">
            <Grid RowDefinitions="Auto,*,Auto"
                  RowSpacing="8">
                <StackPanel Grid.Row="0"
                            Spacing="2"
                            HorizontalAlignment="Left">
                    <TextBlock Text="История цены"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               FontSize="14"
                               HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding SelectedItemName}"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               FontSize="38"
                               FontWeight="Bold"
                               HorizontalAlignment="Left"/>
                </StackPanel>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding ChartBars}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="350"
                                  VerticalAlignment="Bottom">
                                <Border Width="28"
                                        Height="{Binding Height}"
                                        Background="{Binding Fill}"
                                        CornerRadius="12,12,4,4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding ChartBars}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource BrushTextMuted}"
                                       FontSize="11"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="1"
                Background="{DynamicResource BrushBgDeep}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="20"
                Padding="14">
            <Grid RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="10">
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="10"
                      VerticalAlignment="Center">
                    <TextBlock Text="{Binding RecommendationText}"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <Grid Grid.Column="1">
                        <Button x:Name="CalendarToggleButton"
                                Classes="AuctionCalendarTrigger"
                                Content="{Binding SelectedDayText}"
                                Command="{Binding ToggleCalendarCommand}"
                                HorizontalAlignment="Right"/>
                        <Popup IsOpen="{Binding IsCalendarOpen, Mode=TwoWay}"
                               IsLightDismissEnabled="True"
                               OverlayDismissEventPassThrough="True"
                               ShouldUseOverlayLayer="True"
                               Topmost="True"
                               Placement="BottomEdgeAlignedRight"
                               PlacementTarget="{Binding #CalendarToggleButton}"
                               VerticalOffset="8">
                            <Border Classes="AuctionCalendarPanel">
                                <StackPanel Spacing="6">
                                    <UniformGrid Columns="7">
                                        <TextBlock Text="Пн" Classes="AuctionCalendarWeekLabel"/>
                                        <TextBlock Text="Вт" Classes="AuctionCalendarWeekLabel"/>
                                        <TextBlock Text="Ср" Classes="AuctionCalendarWeekLabel"/>
                                        <TextBlock Text="Чт" Classes="AuctionCalendarWeekLabel"/>
                                        <TextBlock Text="Пт" Classes="AuctionCalendarWeekLabel"/>
                                        <TextBlock Text="Сб" Classes="AuctionCalendarWeekLabel"/>
                                        <TextBlock Text="Вс" Classes="AuctionCalendarWeekLabel"/>
                                    </UniformGrid>
                                    <ItemsControl ItemsSource="{Binding CalendarDays}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="7"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Classes="AuctionDayCell"
                                                        Classes.SelectedDayCell="{Binding IsSelected}"
                                                        Classes.DisabledDayCell="{Binding IsUnavailable}"
                                                        Classes.PlaceholderDayCell="{Binding IsPlaceholder}"
                                                        IsEnabled="{Binding IsAvailable}"
                                                        Command="{ReflectionBinding DataContext.SelectDayCommand, ElementName=Root}"
                                                        CommandParameter="{Binding Date}"
                                                        Content="{Binding DayNumber}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>

                <Grid Grid.Row="1"
                      ColumnDefinitions="1*,1*,1*"
                      ColumnSpacing="10">
                    <Border Grid.Column="0"
                            Background="#0CFFFFFF"
                            BorderBrush="#4A3382"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12,10"
                            BoxShadow="0 10 20 #00000033">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Текущая"
                                       Foreground="#A9A0CA"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding CurrentPriceText}"
                                       Foreground="#FFFFFF"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="#0CFFFFFF"
                            BorderBrush="#4A3382"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12,10"
                            BoxShadow="0 10 20 #00000033">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Минимум"
                                       Foreground="#A9A0CA"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding MinPriceText}"
                                       Foreground="#FFFFFF"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#0CFFFFFF"
                            BorderBrush="#4A3382"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12,10"
                            BoxShadow="0 10 20 #00000033">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Средняя"
                                       Foreground="#A9A0CA"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding AvgPriceText}"
                                       Foreground="#FFFFFF"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2"
                      ColumnDefinitions="1*,1*"
                      ColumnSpacing="10">
                    <Border Grid.Column="0"
                            Background="#0CFFFFFF"
                            BorderBrush="#4A3382"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12,10"
                            BoxShadow="0 10 20 #00000033">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Максимум"
                                       Foreground="#A9A0CA"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding MaxPriceText}"
                                       Foreground="#FFFFFF"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="#0CFFFFFF"
                            BorderBrush="#4A3382"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12,10"
                            BoxShadow="0 10 20 #00000033">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Тренд"
                                           Foreground="#A9A0CA"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding TrendText}"
                                           Foreground="#FFFFFF"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding TrendDisplayText}"
                                       Foreground="{Binding TrendBrush}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Grid.Row="1"
                Background="#0A090F"
                BorderBrush="#251A3E"
                BorderThickness="1"
                CornerRadius="20"
                Padding="14">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="Активные лоты"
                           Foreground="#F3EEFF"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>
                <ScrollViewer Grid.Row="1"
                              Padding="0,0,6,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ActiveLots}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#15111F"
                                        BorderBrush="#4A3382"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="12"
                                        Margin="0,0,0,10"
                                        BoxShadow="0 8 18 #0000002E">
                                    <Grid ColumnDefinitions="48,*,Auto"
                                          RowDefinitions="Auto,Auto,Auto"
                                          ColumnSpacing="10">
                                        <Border Grid.RowSpan="3"
                                                Width="48"
                                                Height="48"
                                                CornerRadius="14"
                                                Background="#241B3E"
                                                BorderBrush="#5A3D99"
                                                BorderThickness="1"
                                                ClipToBounds="True">
                                            <Image Source="{Binding IconPath, Converter={StaticResource IconPathToBitmapConverter}}"
                                                   Stretch="UniformToFill"
                                                   Width="48"
                                                   Height="48"/>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DisplayName}"
                                                   Foreground="#F5F2FF"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding CurrentPrice, StringFormat={}{0:N0} ₽}"
                                                   Foreground="#FFFFFF"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Text="{Binding PriceStatus}"
                                                   Foreground="#A98BFF"
                                                   FontSize="12"/>
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="2"
                                                   Text="{Binding BuyoutPrice, StringFormat=Выкуп {0:N0} ₽}"
                                                   Foreground="#8C86A5"
                                                   FontSize="12"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="1"
                                                   Text="{Binding StartPrice, StringFormat=Старт {0:N0} ₽}"
                                                   Foreground="#76708E"
                                                   FontSize="12"/>
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="2"
                                                   Text="{Binding EndTime, StringFormat=До {0:dd.MM HH:mm}}"
                                                   Foreground="#76708E"
                                                   FontSize="12"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
