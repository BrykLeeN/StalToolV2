<UserControl
    x:Class="StalTool.Views.Pages.AuctionPriceChartPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:StalTool.ViewModels.Auction.Sections"
    xmlns:models="using:StalTool.Models"
    mc:Ignorable="d"
    x:DataType="vm:AuctionPriceChartViewModel"
    x:Name="Root">

    <Grid ColumnDefinitions="280,*,340"
          RowDefinitions="Auto,*"
          Margin="18">

        <!-- Верхние карточки -->
        <Grid Grid.ColumnSpan="3"
              ColumnDefinitions="1.1*,1.1*,1.1*,1.4*,Auto"
              ColumnSpacing="12"
              Margin="0,0,0,16">

            <Border Grid.Column="0"
                    Padding="16"
                    CornerRadius="16"
                    Background="#141122"
                    BorderBrush="#2A1F46"
                    BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock Text="Минимум" Foreground="#9F9BB3" FontSize="13"/>
                    <TextBlock Text="{Binding MinPriceText}" Foreground="#FFFFFF" FontSize="24" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Padding="16"
                    CornerRadius="16"
                    Background="#141122"
                    BorderBrush="#2A1F46"
                    BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock Text="Средняя" Foreground="#9F9BB3" FontSize="13"/>
                    <TextBlock Text="{Binding AvgPriceText}" Foreground="#FFFFFF" FontSize="24" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Padding="16"
                    CornerRadius="16"
                    Background="#141122"
                    BorderBrush="#2A1F46"
                    BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock Text="Максимум" Foreground="#9F9BB3" FontSize="13"/>
                    <TextBlock Text="{Binding MaxPriceText}" Foreground="#FFFFFF" FontSize="24" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3"
                    Padding="16"
                    CornerRadius="16"
                    Background="#141122"
                    BorderBrush="#2A1F46"
                    BorderThickness="1">
                <Grid ColumnDefinitions="92,*" ColumnSpacing="14">
                    <Border Width="76"
                            Height="76"
                            CornerRadius="38"
                            BorderBrush="{Binding TrendBrush}"
                            BorderThickness="4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding TrendDisplayText}"
                                   Foreground="{Binding TrendBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="18"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="{Binding TrendText}" Foreground="#FFFFFF" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding RecommendationText}" Foreground="#AFA9C4" FontSize="13"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Column="4"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                <ItemsControl ItemsSource="{Binding Periods}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Button Command="{ReflectionBinding DataContext.SetPeriodCommand, ElementName=Root}"
                                    CommandParameter="{Binding .}"
                                    Content="{Binding .}"
                                    MinWidth="54"
                                    Height="36"
                                    Padding="14,0"
                                    CornerRadius="10"
                                    Background="#19152B"
                                    Foreground="#E7E2F6"
                                    BorderBrush="#31244F"
                                    BorderThickness="1"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <!-- Левая панель -->
        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#110E1D"
                BorderBrush="#2A1F46"
                BorderThickness="1"
                CornerRadius="18"
                Padding="14">
            <StackPanel Spacing="12">
                <TextBlock Text="Категории"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:AuctionCategoryGroup">
                                <StackPanel Margin="0,0,0,14" Spacing="8">
                                    <TextBlock Text="{Binding CategoryName}"
                                               Foreground="#B7B1CE"
                                               FontWeight="SemiBold"
                                               FontSize="14"/>

                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:AuctionCatalogItem">
                                                <Button Command="{ReflectionBinding DataContext.SelectItemCommand, ElementName=Root}"
                                                        CommandParameter="{Binding .}"
                                                        Background="#181427"
                                                        BorderBrush="#2E2450"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="12"
                                                        HorizontalContentAlignment="Stretch">
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="#F4F1FF"
                                                                   FontSize="13"
                                                                   VerticalAlignment="Center"/>
                                                        <Border Grid.Column="1"
                                                                Background="#261D44"
                                                                CornerRadius="8"
                                                                Padding="8,3">
                                                            <TextBlock Text="{Binding Rank}"
                                                                       Foreground="#CBA7FF"
                                                                       FontSize="11"/>
                                                        </Border>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Центр -->
        <Border Grid.Row="1"
                Grid.Column="1"
                Background="#110E1D"
                BorderBrush="#2A1F46"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16"
                Margin="16,0">
            <Grid RowDefinitions="Auto,*,Auto">
                <StackPanel Spacing="4" Margin="0,0,0,10">
                    <TextBlock Text="История цены"
                               Foreground="#AFA9C4"
                               FontSize="13"/>
                    <TextBlock Text="{Binding SelectedItemName}"
                               Foreground="#FFFFFF"
                               FontSize="24"
                               FontWeight="Bold"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Background="#0C0916"
                        CornerRadius="16"
                        Padding="18">
                    <Grid RowDefinitions="*,Auto">
                        <ItemsControl ItemsSource="{Binding ChartBars}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:AuctionPriceChartViewModel+ChartBarItem">
                                    <Grid RowDefinitions="Auto,*,Auto" Margin="4,0">
                                        <TextBlock Text="{Binding ValueText}"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#AFA9C4"
                                                   FontSize="11"
                                                   Margin="0,0,0,8"/>

                                        <Grid Grid.Row="1"
                                              VerticalAlignment="Bottom"
                                              Height="210">
                                            <Border Width="22"
                                                    Height="{Binding Height}"
                                                    Background="{Binding Fill}"
                                                    CornerRadius="10,10,4,4"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Bottom"/>
                                        </Grid>

                                        <TextBlock Grid.Row="2"
                                                   Text="{Binding Label}"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#8D86A6"
                                                   FontSize="11"
                                                   Margin="0,8,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Grid.Row="1"
                                   Text="Башенный концепт-график • позже можно заменить на OxyPlot/кастомный canvas"
                                   Foreground="#6E6786"
                                   FontSize="11"
                                   HorizontalAlignment="Right"
                                   Margin="0,12,0,0"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Правая панель -->
        <Border Grid.Row="1"
                Grid.Column="2"
                Background="#110E1D"
                BorderBrush="#2A1F46"
                BorderThickness="1"
                CornerRadius="18"
                Padding="14">
            <StackPanel Spacing="12">
                <TextBlock Text="Активные лоты"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ActiveLots}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:AuctionLot">
                                <Border Background="#181427"
                                        BorderBrush="#2E2450"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="12"
                                        Margin="0,0,0,10">
                                    <Grid RowDefinitions="Auto,Auto,Auto"
                                          ColumnDefinitions="44,*,Auto"
                                          ColumnSpacing="10">
                                        <Border Width="44"
                                                Height="44"
                                                CornerRadius="12"
                                                Background="#241C3F"/>

                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="#F4F1FF"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding PriceStatus}"
                                                       Foreground="#BFA9FF"
                                                       FontSize="12"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="2">
                                            <TextBlock Text="{Binding CurrentPrice, StringFormat={}{0:N0} ₽}"
                                                       Foreground="#FFFFFF"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding BuyoutPrice, StringFormat=Выкуп {0:N0} ₽}"
                                                       Foreground="#9E97B8"
                                                       FontSize="12"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Grid.ColumnSpan="2"
                                                   Text="{Binding StartPrice, StringFormat=Старт {0:N0} ₽}"
                                                   Foreground="#8D86A6"
                                                   FontSize="12"
                                                   Margin="0,8,0,0"/>

                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="1"
                                                   Grid.ColumnSpan="2"
                                                   Text="{Binding EndTime, StringFormat=До {0:dd.MM HH:mm}}"
                                                   Foreground="#756E92"
                                                   FontSize="11"
                                                   Margin="0,6,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
