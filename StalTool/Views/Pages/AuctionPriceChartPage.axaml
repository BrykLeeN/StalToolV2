<UserControl
    x:Class="StalTool.Views.Pages.AuctionPriceChartPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:StalTool.ViewModels.Auction.Sections"
    x:Name="Root"
    Classes="AuctionPriceChartPage"
    x:DataType="vm:AuctionPriceChartViewModel">

    <Grid Margin="14"
          ColumnDefinitions="280,1.55*,1.25*"
          RowDefinitions="1.35*,0.85*"
          ColumnSpacing="12"
          RowSpacing="12">

        <Border Grid.Column="0"
                Grid.RowSpan="2"
                Background="#0A090F"
                BorderBrush="#251A3E"
                BorderThickness="1"
                CornerRadius="22"
                Padding="14">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="Категории"
                           Foreground="#F3EEFF"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <ScrollViewer Grid.Row="1"
                              Padding="0,0,6,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,10"
                                            Spacing="8">
                                    <ToggleButton x:Name="CategoryToggle"
                                                  Classes="CategoryToggle"
                                                  IsChecked="True"
                                                  Focusable="False">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="8">
                                            <TextBlock Text="{Binding CategoryName}"
                                                       Classes="CategoryTitle"
                                                       Foreground="#D6D0ED"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Classes="CategoryArrow"
                                                       Text="⌄"
                                                       Foreground="#CDBFFF"
                                                       FontSize="18"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </ToggleButton>

                                    <ItemsControl ItemsSource="{Binding Items}"
                                                  Margin="8,0,8,0"
                                                  IsVisible="{Binding #CategoryToggle.IsChecked}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{ReflectionBinding DataContext.SelectItemCommand, ElementName=Root}"
                                                        Classes="CategoryItemBtn"
                                                        CommandParameter="{Binding .}"
                                                        Margin="0,0,0,8"
                                                        HorizontalContentAlignment="Stretch">
                                                    <Grid ColumnDefinitions="*,Auto"
                                                          ColumnSpacing="8">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="#ECE8F8"
                                                                   FontSize="13"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <Border Grid.Column="1"
                                                                Background="#261B42"
                                                                BorderBrush="#5A3D99"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Padding="7,2"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Rank}"
                                                                       Foreground="#C9A7FF"
                                                                       FontSize="10"/>
                                                        </Border>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="#0A090F"
                BorderBrush="#251A3E"
                BorderThickness="1"
                CornerRadius="22"
                Padding="18">
            <Grid RowDefinitions="Auto,*,Auto"
                  RowSpacing="8">
                <StackPanel Grid.Row="0"
                            Spacing="2"
                            HorizontalAlignment="Left">
                    <TextBlock Text="История цены"
                               Foreground="#8D86A6"
                               FontSize="14"
                               HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding SelectedItemName}"
                               Foreground="#FFFFFF"
                               FontSize="38"
                               FontWeight="Bold"
                               HorizontalAlignment="Left"/>
                </StackPanel>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding ChartBars}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="350"
                                  VerticalAlignment="Bottom">
                                <Border Width="28"
                                        Height="{Binding Height}"
                                        Background="{Binding Fill}"
                                        CornerRadius="12,12,4,4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding ChartBars}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}"
                                       HorizontalAlignment="Center"
                                       Foreground="#787194"
                                       FontSize="11"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="1"
                Background="#0A090F"
                BorderBrush="#251A3E"
                BorderThickness="1"
                CornerRadius="20"
                Padding="14">
            <Grid RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="10">
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="10"
                      VerticalAlignment="Center">
                    <TextBlock Text="{Binding RecommendationText}"
                               Foreground="#9D94BC"
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <ItemsControl Grid.Column="1"
                                  ItemsSource="{Binding Periods}"
                                  HorizontalAlignment="Right">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{ReflectionBinding DataContext.SetPeriodCommand, ElementName=Root}"
                                        CommandParameter="{Binding .}"
                                        Content="{Binding .}"
                                        MinWidth="54"
                                        Height="34"
                                        Padding="12,0"
                                        CornerRadius="10"
                                        Background="#19142A"
                                        BorderBrush="#52348E"
                                        BorderThickness="1"
                                        Foreground="#EFE9FF"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <Grid Grid.Row="1"
                      ColumnDefinitions="1*,1*,1*"
                      ColumnSpacing="10">
                    <Border Grid.Column="0"
                            Background="#0CFFFFFF"
                            BorderBrush="#4A3382"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12,10"
                            BoxShadow="0 10 20 #00000033">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Текущая"
                                       Foreground="#A9A0CA"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding CurrentPriceText}"
                                       Foreground="#FFFFFF"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="#0CFFFFFF"
                            BorderBrush="#4A3382"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12,10"
                            BoxShadow="0 10 20 #00000033">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Минимум"
                                       Foreground="#A9A0CA"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding MinPriceText}"
                                       Foreground="#FFFFFF"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#0CFFFFFF"
                            BorderBrush="#4A3382"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12,10"
                            BoxShadow="0 10 20 #00000033">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Средняя"
                                       Foreground="#A9A0CA"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding AvgPriceText}"
                                       Foreground="#FFFFFF"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2"
                      ColumnDefinitions="1*,1*"
                      ColumnSpacing="10">
                    <Border Grid.Column="0"
                            Background="#0CFFFFFF"
                            BorderBrush="#4A3382"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12,10"
                            BoxShadow="0 10 20 #00000033">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Максимум"
                                       Foreground="#A9A0CA"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding MaxPriceText}"
                                       Foreground="#FFFFFF"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="#0CFFFFFF"
                            BorderBrush="#4A3382"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12,10"
                            BoxShadow="0 10 20 #00000033">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Тренд"
                                           Foreground="#A9A0CA"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding TrendText}"
                                           Foreground="#FFFFFF"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding TrendDisplayText}"
                                       Foreground="{Binding TrendBrush}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Grid.Row="1"
                Background="#0A090F"
                BorderBrush="#251A3E"
                BorderThickness="1"
                CornerRadius="20"
                Padding="14">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="Активные лоты"
                           Foreground="#F3EEFF"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>
                <ScrollViewer Grid.Row="1"
                              Padding="0,0,6,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ActiveLots}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#15111F"
                                        BorderBrush="#4A3382"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="12"
                                        Margin="0,0,0,10"
                                        BoxShadow="0 8 18 #0000002E">
                                    <Grid ColumnDefinitions="48,*,Auto"
                                          RowDefinitions="Auto,Auto,Auto"
                                          ColumnSpacing="10">
                                        <Border Grid.RowSpan="3"
                                                Width="48"
                                                Height="48"
                                                CornerRadius="14"
                                                Background="#241B3E"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DisplayName}"
                                                   Foreground="#F5F2FF"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding CurrentPrice, StringFormat={}{0:N0} ₽}"
                                                   Foreground="#FFFFFF"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Text="{Binding PriceStatus}"
                                                   Foreground="#A98BFF"
                                                   FontSize="12"/>
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="2"
                                                   Text="{Binding BuyoutPrice, StringFormat=Выкуп {0:N0} ₽}"
                                                   Foreground="#8C86A5"
                                                   FontSize="12"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="1"
                                                   Text="{Binding StartPrice, StringFormat=Старт {0:N0} ₽}"
                                                   Foreground="#76708E"
                                                   FontSize="12"/>
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="2"
                                                   Text="{Binding EndTime, StringFormat=До {0:dd.MM HH:mm}}"
                                                   Foreground="#76708E"
                                                   FontSize="12"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
