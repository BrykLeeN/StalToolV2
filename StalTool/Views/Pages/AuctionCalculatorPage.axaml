<UserControl
    x:Class="StalTool.Views.Pages.AuctionCalculatorPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:StalTool.Converters"
    xmlns:controls="using:StalTool.Views.Controls"
    xmlns:models="using:StalTool.Models"
    xmlns:vm="using:StalTool.ViewModels.Auction.Sections"
    x:Name="Root"
    Classes="AuctionCalculatorPage"
    x:DataType="vm:AuctionCalculatorViewModel">
    <UserControl.Resources>
        <conv:IconPathToBitmapConverter x:Key="IconPathToBitmapConverter"/>
    </UserControl.Resources>

    <Grid Margin="12"
          ColumnDefinitions="272,*"
          RowDefinitions="1.56*,0.74*"
          ColumnSpacing="12"
          RowSpacing="10">
        <Border Grid.RowSpan="2"
                Grid.Column="0"
                Classes="CalculatorPanel">
            <controls:AuctionCategorySelector Categories="{Binding Categories}"
                                              Classes="AuctionPriceChartPage"
                                              SearchText="{Binding SearchText, Mode=TwoWay}"
                                              ClearSearchCommand="{Binding ClearSearchCommand}"
                                              ToggleOrSelectItemCommand="{Binding ToggleOrSelectItemCommand}"
                                              SelectItemCommand="{Binding SelectItemCommand}"
                                              CollapseCategoryByItemCommand="{Binding CollapseCategoryByItemCommand}"/>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="0"
                ClipToBounds="True"
                Classes="CalculatorPanel">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                  RowSpacing="6">
                <StackPanel Spacing="2">
                    <TextBlock Text="Сделка"
                               FontSize="19"
                               FontWeight="Bold"
                               Foreground="{DynamicResource BrushTextPrimary}"/>
                    <TextBlock Text="{Binding SelectedItem.DisplayName}"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Grid Grid.Row="1"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="8">
                    <Border Classes="CalculatorMetricCard">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Базовая сумма партии (ориентир рынка)"
                                       Classes="CalculatorMetricTitle"/>
                            <TextBox Classes="CalculatorInput"
                                     Watermark="Сумма за партию"
                                     Text="{Binding BasePriceInput, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1"
                            Classes="CalculatorMetricCard">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Сумма фактической продажи партии"
                                       Classes="CalculatorMetricTitle"/>
                            <TextBox Classes="CalculatorInput"
                                     Watermark="Сумма продажи"
                                     Text="{Binding ActualSellPriceInput, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2"
                      ColumnDefinitions="1.2*,0.9*,1*"
                      ColumnSpacing="8">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Наценка для предложения покупки"
                                   Classes="CalculatorMetricTitle"/>
                        <Grid ColumnDefinitions="*,26"
                              ColumnSpacing="6">
                            <ComboBox Grid.Column="0"
                                      Classes="CalculatorCombo"
                                      ItemsSource="{Binding MarkupOptions}"
                                      SelectedItem="{Binding SelectedMarkupPercent, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="1"
                                       Text="%"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Spacing="6">
                        <TextBlock Text="Количество"
                                   Classes="CalculatorMetricTitle"/>
                        <TextBox Classes="CalculatorInput"
                                 HorizontalContentAlignment="Center"
                                 Text="{Binding QuantityInput, Mode=TwoWay}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Spacing="6">
                        <TextBlock Text="Канал продажи"
                                   Classes="CalculatorMetricTitle"/>
                        <ComboBox Classes="CalculatorCombo"
                                  ItemsSource="{Binding SaleChannels}"
                                  SelectedItem="{Binding SelectedSaleChannel, Mode=TwoWay}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="3"
                           Text="{Binding SaleFeeText}"
                           Foreground="{DynamicResource BrushTextSecondary}"/>

                <Grid Grid.Row="4"
                      RowDefinitions="Auto,Auto,Auto"
                      ColumnSpacing="8"
                      RowSpacing="8">
                    <Grid Grid.Row="0"
                          ColumnDefinitions="*,*,*"
                          ColumnSpacing="8">
                        <Border Classes="CalculatorMetricCard">
                            <StackPanel Spacing="5">
                                <TextBlock Text="Предложение покупки (1 шт)"
                                           Classes="CalculatorMetricTitle"/>
                                <TextBlock Text="{Binding OfferBuyUnitPriceText}"
                                           Classes="CalculatorMetricValueBig"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1"
                                Classes="CalculatorMetricCard">
                            <StackPanel Spacing="5">
                                <TextBlock Text="Профит (1 шт)"
                                           Classes="CalculatorMetricTitle"/>
                                <TextBlock Text="{Binding ProfitPerUnitText}"
                                           Classes="CalculatorMetricValue"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2"
                                Classes="CalculatorMetricCard">
                            <StackPanel Spacing="5">
                                <TextBlock Text="Точка безубытка (1 шт)"
                                           Classes="CalculatorMetricTitle"/>
                                <TextBlock Text="{Binding BreakEvenSellPriceText}"
                                           Classes="CalculatorMetricValue"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="*,*,*"
                          ColumnSpacing="8">
                        <Border Classes="CalculatorMetricCard">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Покупка (партия)"
                                           Classes="CalculatorMetricTitle"/>
                                <TextBlock Text="{Binding OfferBuyTotalText}"
                                           Classes="CalculatorMetricValue"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1"
                                Classes="CalculatorMetricCard">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Продажа (партия)"
                                           Classes="CalculatorMetricTitle"/>
                                <TextBlock Text="{Binding GrossSellTotalText}"
                                           Classes="CalculatorMetricValue"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2"
                                Classes="CalculatorMetricCard">
                            <StackPanel Spacing="3">
                                <TextBlock Text="После комиссии"
                                           Classes="CalculatorMetricTitle"/>
                                <TextBlock Text="{Binding NetSellTotalText}"
                                           Classes="CalculatorMetricValue"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,200"
                          ColumnSpacing="8">
                        <Border Classes="CalculatorProfitBar">
                            <TextBlock Text="{Binding ProfitTotalText}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding ProfitTotalBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                        <Button Grid.Column="1"
                                Classes="CalculatorActionButton"
                                Content="В историю сделок"
                                Command="{Binding AddTradeToHistoryCommand}"/>
                    </Grid>
                    </Grid>
                </Grid>
        </Border>

        <Grid Grid.Column="1"
              Grid.Row="1"
              ColumnDefinitions="1.25*,0.95*"
              ColumnSpacing="12">
            <Border Grid.Column="0"
                    ClipToBounds="True"
                    Classes="CalculatorPanel">
                <StackPanel Spacing="6">
                    <TextBlock Text="Ориентиры"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushTextPrimary}"/>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="6">
                        <Border Classes="CalculatorMetricCard">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Реком. продажа (1 шт)" Classes="CalculatorMetricTitle"/>
                                <TextBlock Text="{Binding RecommendedSellUnitPriceText}" Classes="CalculatorMetricValue"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1"
                                Classes="CalculatorMetricCard">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Реком. покупка (1 шт)" Classes="CalculatorMetricTitle"/>
                                <TextBlock Text="{Binding RecommendedBuyUnitPriceText}" Classes="CalculatorMetricValue"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Classes="CalculatorMetricCard">
                        <TextBlock Text="{Binding RecommendedPartyText}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                    </Border>

                    <WrapPanel ItemHeight="26"
                               ItemWidth="54"
                               Orientation="Horizontal">
                        <Button Classes="CalculatorPresetButton" Content="x1" Command="{Binding SetQuantityPresetCommand}" CommandParameter="1"/>
                        <Button Classes="CalculatorPresetButton" Content="x5" Command="{Binding SetQuantityPresetCommand}" CommandParameter="5"/>
                        <Button Classes="CalculatorPresetButton" Content="x10" Command="{Binding SetQuantityPresetCommand}" CommandParameter="10"/>
                        <Button Classes="CalculatorPresetButton" Content="x25" Command="{Binding SetQuantityPresetCommand}" CommandParameter="25"/>
                        <Button Classes="CalculatorPresetButton" Content="x50" Command="{Binding SetQuantityPresetCommand}" CommandParameter="50"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    ClipToBounds="True"
                    Classes="CalculatorPanel">
                <StackPanel Spacing="6">
                    <TextBlock Text="Проценты"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushTextPrimary}"/>

                    <Grid ColumnDefinitions="*,74"
                          ColumnSpacing="6">
                        <TextBox Classes="CalculatorInput" Watermark="База" Text="{Binding QuickBaseInput, Mode=TwoWay}"/>
                        <TextBox Grid.Column="1" Classes="CalculatorInput" Watermark="%" Text="{Binding QuickPercentInput, Mode=TwoWay}"/>
                    </Grid>
                    <TextBlock Text="{Binding QuickResultText}" Foreground="{DynamicResource BrushTextSecondary}"/>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="6">
                        <TextBox Classes="CalculatorInput" Watermark="Было" Text="{Binding QuickFromInput, Mode=TwoWay}"/>
                        <TextBox Grid.Column="1" Classes="CalculatorInput" Watermark="Стало" Text="{Binding QuickToInput, Mode=TwoWay}"/>
                    </Grid>
                    <TextBlock Text="{Binding QuickChangeText}" Foreground="{DynamicResource BrushTextSecondary}"/>

                    <TextBox Classes="CalculatorInput"
                             Watermark="(12000*1.12)-600"
                             Text="{Binding ExpressionInput, Mode=TwoWay}"/>
                    <TextBlock Text="{Binding ExpressionResultText}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushTextPrimary}"/>
                    <Button Classes="CalculatorActionButton"
                            Content="Подставить ориентир"
                            Command="{Binding ApplyRecommendedSellPriceCommand}"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.RowSpan="2"
                Grid.ColumnSpan="2"
                Classes="CalculatorOverlayBackdrop"
                IsVisible="{Binding IsActiveLotsOverlayOpen}"
                ZIndex="50">
            <Border Width="980"
                    MaxHeight="510"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0"
                    Classes="CalculatorOverlayPanel">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0"
                          ColumnDefinitions="*,Auto"
                          Margin="0,0,0,10">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding ActiveLotsHeaderText}"
                                       Foreground="#F3EEFF"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Выберите лот: цена и количество подставятся в расчёт."
                                       Foreground="#A8A0C5"
                                       FontSize="12"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="CalculatorOverlayCloseButton"
                                Width="36"
                                Height="36"
                                FontSize="16"
                                Content="×"
                                Command="{Binding CloseActiveLotsOverlayCommand}"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  Padding="0,0,6,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding ActiveLots}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:AuctionLot">
                                    <Button Command="{ReflectionBinding DataContext.ApplyLotToCalculatorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding .}"
                                            Classes="CalculatorLotButton"
                                            HorizontalContentAlignment="Stretch"
                                            Margin="0,0,0,10"
                                            Padding="0"
                                            Background="Transparent">
                                        <Border Classes="CalculatorLotCard"
                                                Padding="12">
                                            <Grid ColumnDefinitions="48,*,Auto"
                                                  RowDefinitions="Auto,Auto,Auto"
                                                  ColumnSpacing="10">
                                                <Border Grid.RowSpan="3"
                                                        Width="48"
                                                        Height="48"
                                                        CornerRadius="14"
                                                        Background="#241B3E"
                                                        BorderBrush="#5A3D99"
                                                        BorderThickness="1"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <Image Source="{Binding IconPath, Converter={StaticResource IconPathToBitmapConverter}}"
                                                               Stretch="UniformToFill"
                                                               Width="48"
                                                               Height="48"/>
                                                        <Border HorizontalAlignment="Right"
                                                                VerticalAlignment="Bottom"
                                                                Margin="0,0,2,2"
                                                                IsVisible="{Binding ShowAmountBadge}"
                                                                Background="#CC11111A"
                                                                BorderBrush="#8B6BCA"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Padding="4,1">
                                                            <TextBlock Text="{Binding Amount}"
                                                                       Foreground="#F5F2FF"
                                                                       FontSize="10"
                                                                       FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DisplayName}"
                                                           Foreground="#F5F2FF"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding CurrentPrice, StringFormat={}{0:N0} ₽}"
                                                           Foreground="#FFFFFF"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Right"/>
                                                <TextBlock Grid.Row="1"
                                                           Grid.Column="1"
                                                           Text="{Binding PriceStatus}"
                                                           Foreground="#A98BFF"
                                                           FontSize="12"/>
                                                <TextBlock Grid.Row="1"
                                                           Grid.Column="2"
                                                           Text="{Binding BuyoutPrice, StringFormat=Выкуп {0:N0} ₽}"
                                                           Foreground="#8C86A5"
                                                           FontSize="12"
                                                           HorizontalAlignment="Right"/>
                                                <TextBlock Grid.Row="2"
                                                           Grid.Column="1"
                                                           Text="{Binding StartPrice, StringFormat=Старт {0:N0} ₽}"
                                                           Foreground="#76708E"
                                                           FontSize="12"/>
                                                <TextBlock Grid.Row="2"
                                                           Grid.Column="2"
                                                           Text="{Binding Amount, StringFormat=Количество {0}}"
                                                           Foreground="#76708E"
                                                           FontSize="12"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
