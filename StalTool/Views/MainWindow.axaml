<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:StalTool.ViewModels"
        x:Class="StalTool.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="StalTool"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="600"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        SystemDecorations="Full"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Themes/Colors.axaml"/>
                <ResourceInclude Source="/Themes/Controls.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="16" ClipToBounds="True"
            BorderThickness="1"
            BorderBrush="{StaticResource BrushBorder}"
            Background="{StaticResource BrushBgBase}">
        <Grid ColumnDefinitions="60,*">

            <!-- =============================================
                 SIDEBAR
                 Структура каждой кнопки:
                   Panel (60x52) — зона клика
                     Border.NavBtn (44x44) — hover + активный фон
                       Image (32x32) — иконка
                     Border (3x22) — активная полоска
            ============================================= -->
            <Border Grid.Column="0"
                    Background="{StaticResource SidebarGradient}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,0,1,0">
                <Grid RowDefinitions="70,*,Auto">

                    <!-- Логотип -->
                    <Image Grid.Row="0"
                           Source="/Assets/Icons/Logo_Main.png"
                           Width="46" Height="56"
                           Stretch="Uniform"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

                    <!-- Кнопки навигации -->
                    <StackPanel Grid.Row="1"
                                VerticalAlignment="Top"
                                Margin="0,10,0,0"
                                Spacing="4">

                        <!-- АУКЦИОН -->
                        <Panel Width="60" Height="52" Background="Transparent"
                               Cursor="Hand"
                               PointerPressed="NavBtn_PointerPressed"
                               Tag="Auction">
                            <Border Classes="NavBtn">
                                <Grid>
                                    <Border CornerRadius="10"
                                            Opacity="0.18"
                                            IsVisible="{Binding IsAuctionActive}">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                <GradientStop Offset="0" Color="#9B59FF"/>
                                                <GradientStop Offset="1" Color="#E040C8"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    
                                    <Image Source="/Assets/Icons/AuctionEx.png"
                                       Width="32" Height="32"
                                       Opacity="0.65"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                                </Grid>
                            </Border>               
                            <!-- Активная полоска — прибита к правому краю Panel -->
                            <Border Width="3" Height="20" CornerRadius="2"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    IsVisible="{Binding IsAuctionActive}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
                                        <GradientStop Offset="0" Color="#9B59FF"/>
                                        <GradientStop Offset="1" Color="#E040C8"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Panel>

                        <!-- АРСЕН -->
                        <Panel Width="60" Height="52" Background="Transparent"
                               Cursor="Hand"
                               PointerPressed="NavBtn_PointerPressed"
                               Tag="Arsen">
                            <Border Classes="NavBtn">
                                <Grid>
                                    <Border CornerRadius="10"
                                            Opacity="0.18"
                                            IsVisible="{Binding IsArsenActive}">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                <GradientStop Offset="0" Color="#9B59FF"/>
                                                <GradientStop Offset="1" Color="#E040C8"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>

                                    <Image Source="/Assets/Icons/ArsenEx.png"
                                           Width="32" Height="32"
                                           Opacity="0.65"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Width="3" Height="20" CornerRadius="2"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    IsVisible="{Binding IsArsenActive}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
                                        <GradientStop Offset="0" Color="#9B59FF"/>
                                        <GradientStop Offset="1" Color="#E040C8"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Panel>

                        <!-- ИСТОРИЯ -->
                        <Panel Width="60" Height="52" Background="Transparent"
                               Cursor="Hand"
                               PointerPressed="NavBtn_PointerPressed"
                               Tag="History">
                            <Border Classes="NavBtn">
                                <Grid>
                                    
                                    <Border CornerRadius="10"
                                            Opacity="0.18"
                                            IsVisible="{Binding IsHistoryActive}">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                <GradientStop Offset="0" Color="#9B59FF"/>
                                                <GradientStop Offset="1" Color="#E040C8"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        </Border>
                                    <Image Source="/Assets/Icons/HistoryEx.png"
                                           Width="32" Height="32"
                                           Opacity="0.65"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Width="3" Height="20" CornerRadius="2"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    IsVisible="{Binding IsHistoryActive}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
                                        <GradientStop Offset="0" Color="#9B59FF"/>
                                        <GradientStop Offset="1" Color="#E040C8"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Panel>

                        <!-- РАДАР -->
                        <Panel Width="60" Height="52" Background="Transparent"
                               Cursor="Hand"
                               PointerPressed="NavBtn_PointerPressed"
                               Tag="Radar">
                            <Border Classes="NavBtn">
                                <Grid>
                                    <Border CornerRadius="10"
                                            Opacity="0.18"
                                            IsVisible="{Binding IsRadarActive}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                            <GradientStop Offset="0" Color="#9B59FF"/>
                                            <GradientStop Offset="1" Color="#E040C8"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    </Border>
                                    <Image Source="/Assets/Icons/RadarEx.png"
                                           Width="32" Height="32"
                                           Opacity="0.65"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Width="3" Height="20" CornerRadius="2"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    IsVisible="{Binding IsRadarActive}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
                                        <GradientStop Offset="0" Color="#9B59FF"/>
                                        <GradientStop Offset="1" Color="#E040C8"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Panel>

                    </StackPanel>

                    <!-- НАСТРОЙКИ снизу -->
                    <Panel Grid.Row="2"
                           Width="60" Height="52"
                           Background="Transparent"
                           Cursor="Hand"
                           Margin="0,0,0,14"
                           PointerPressed="NavBtn_PointerPressed"
                           Tag="Settings">
                        <Border Classes="NavBtn">
                            <Grid>
                                <Border CornerRadius="10"
                                        Opacity="0.18"
                                        IsVisible="{Binding IsSettingsActive}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                            <GradientStop Offset="0" Color="#9B59FF"/>
                                            <GradientStop Offset="1" Color="#E040C8"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Image Source="/Assets/Icons/SettingsEx.png"
                                       Width="32" Height="32"
                                       Opacity="0.65"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Border Width="3" Height="20" CornerRadius="2"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                IsVisible="{Binding IsSettingsActive}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
                                    <GradientStop Offset="0" Color="#9B59FF"/>
                                    <GradientStop Offset="1" Color="#E040C8"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Panel>

                </Grid>
            </Border>

            <!-- =============================================
                 ОСНОВНОЙ КОНТЕНТ
            ============================================= -->
            <Grid Grid.Column="1" RowDefinitions="48,36,*">

                <!-- TITLEBAR -->
                <Border x:Name="TitleBar" Grid.Row="0"
                        Background="Transparent"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto" Margin="20,0,12,0">

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <TextBlock Text="{Binding CurrentPageTitle}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CurrentPageSubtitle}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    Spacing="8" VerticalAlignment="Center">

                            <!-- Кнопка уведомлений -->
                            <Panel>
                                <Border x:Name="NotifBtn"
                                        Classes="NotifBtn"
                                        Width="32" Height="32" CornerRadius="16"
                                        Background="Transparent"
                                        BorderThickness="1"
                                        BorderBrush="{StaticResource BrushBorder}"
                                        Cursor="Hand"
                                        PointerPressed="NotifBtn_PointerPressed">
                                    <Panel>
                                        <TextBlock Text="🔔" FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="0,-1,0,0"/>
                                        
                                        <Border Width="10" Height="10" CornerRadius="5"
                                                Background="#FF5566"
                                                BorderBrush="#1A1A24"
                                                BorderThickness="1"
                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Margin="0,2,2,0"
                                                IsVisible="{Binding HasUnreadNotifications}"/>
                                    </Panel>
                                </Border>

                                <!-- Popup уведомлений -->
                                <Popup x:Name="NotifPopup"
                                       IsOpen="{Binding IsNotifOpen, Mode=TwoWay}"
                                       IsLightDismissEnabled="True"
                                       OverlayDismissEventPassThrough="True"
                                       ShouldUseOverlayLayer="True"
                                       Topmost="True"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=NotifBtn}"
                                       HorizontalOffset="-160">
                                    <Border x:Name="NotifPopupRoot"
                                            Background="{StaticResource BrushBgCard}"
                                            BorderBrush="{StaticResource BrushBorder}"
                                            BorderThickness="1" CornerRadius="12"
                                            Padding="0" Width="320"
                                            BoxShadow="0 8 32 0 #000000CC">
                                        <StackPanel>

                                            <!-- Заголовок попапа -->
                                            <Grid ColumnDefinitions="*,Auto" Margin="16,12,12,8">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="Уведомления радара"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource BrushTextPrimary}"
                                                               VerticalAlignment="Center"/>
                                                    <!-- Счётчик непрочитанных -->
                                                    <Border MinWidth="22"
                                                            Height="18"
                                                            CornerRadius="9"
                                                            Padding="6,0"
                                                            Background="#17291A"
                                                            BorderBrush="#3FA95A"
                                                            BorderThickness="1"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center"
                                                            IsVisible="{Binding HasUnreadNotifications}">
                                                        <TextBlock Text="{Binding UnreadCount}"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Foreground="#7DFF9A"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   TextAlignment="Center"/>
                                                    </Border>
                                                </StackPanel>
                                                <!-- Кнопка "Прочитать все" -->
                                                <Button Grid.Column="1"
                                                        Content="Прочитать все"
                                                        Theme="{StaticResource MenuButton}"
                                                        FontSize="11"
                                                        Foreground="{StaticResource BrushTextMuted}"
                                                        Command="{Binding MarkAllReadCommand}"
                                                        IsVisible="{Binding HasUnreadNotifications}"/>
                                            </Grid>

                                            <Border Height="1" Background="{StaticResource BrushBorder}"/>

                                            <!-- Список уведомлений -->
                                            <ScrollViewer MaxHeight="320" Padding="0">
                                                <ItemsControl ItemsSource="{Binding RadarNotifications}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Padding="16,10"
                                                                    BorderBrush="{StaticResource BrushBorder}"
                                                                    BorderThickness="0,0,0,1">
                                                                <Border.Styles>
                                                                    <Style Selector="Border:pointerover">
                                                                        <Setter Property="Background" Value="#1C1C28"/>
                                                                    </Style>
                                                                </Border.Styles>
                                                                <Grid ColumnDefinitions="Auto,*,Auto">
                                                                    <!-- Индикатор непрочитанного -->
                                                                    <Border Grid.Column="0"
                                                                            Width="6" Height="6" CornerRadius="3"
                                                                            Background="#9B59FF"
                                                                            VerticalAlignment="Center"
                                                                            Margin="0,0,10,0"
                                                                            IsVisible="{Binding IsUnread}"/>
                                                                    <StackPanel Grid.Column="1" Spacing="3">
                                                                        <!-- Название предмета -->
                                                                        <TextBlock Text="{Binding ItemName}"
                                                                                   FontSize="12" FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource BrushTextPrimary}"/>
                                                                        <!-- Детали -->
                                                                        <TextBlock Text="{Binding Description}"
                                                                                   FontSize="11"
                                                                                   Foreground="{StaticResource BrushTextSecondary}"/>
                                                                        <!-- Время -->
                                                                        <TextBlock Text="{Binding TimeAgo}"
                                                                                   FontSize="10"
                                                                                   Foreground="{StaticResource BrushTextMuted}"/>
                                                                    </StackPanel>
                                                                    <!-- Цена -->
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{Binding PriceText}"
                                                                               FontSize="12" FontWeight="SemiBold"
                                                                               VerticalAlignment="Center"
                                                                               Margin="8,0,0,0">
                                                                        <TextBlock.Foreground>
                                                                            <SolidColorBrush Color="{Binding PriceColor}"/>
                                                                        </TextBlock.Foreground>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>

                                            <!-- Пустое состояние -->
                                            <Border Padding="16,24"
                                                    IsVisible="{Binding !HasNotifications}">
                                                <StackPanel HorizontalAlignment="Center" Spacing="8">
                                                    <TextBlock Text="🔕" FontSize="28"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Нет уведомлений"
                                                               FontSize="13"
                                                               Foreground="{StaticResource BrushTextMuted}"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Добавьте цели в радаре"
                                                               FontSize="11"
                                                               Foreground="{StaticResource BrushTextMuted}"
                                                               HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Кнопка перейти в радар -->
                                            <Border Padding="12,8"
                                                    IsVisible="{Binding HasNotifications}">
                                                <Button Content="Открыть радар →"
                                                        Theme="{StaticResource MenuButton}"
                                                        FontSize="12"
                                                        Foreground="#9B59FF"
                                                        HorizontalAlignment="Center"
                                                        Command="{Binding OpenRadarCommand}"/>
                                            </Border>

                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Panel>

                            <!-- Профиль -->
                            <Border x:Name="UserMenuBtn"
                                    Classes="ProfileBtn"
                                    ClipToBounds="True"
                                    BorderThickness="1"
                                    PointerPressed="UserMenu_PointerPressed">
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                        <GradientStop Offset="0" Color="{Binding TierAccentColor}"/>
                                        <GradientStop Offset="1" Color="{Binding TierAccentColorEnd}"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="24" Height="24" CornerRadius="12">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                <GradientStop Offset="0" Color="#9B59FF"/>
                                                <GradientStop Offset="1" Color="#E040C8"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="{Binding UserInitial}"
                                                   FontSize="11" FontWeight="Bold" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding Username}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrushTextPrimary}"
                                               VerticalAlignment="Center"/>
                                    <Border CornerRadius="8" Padding="6,2">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding TierBgColor}"/>
                                        </Border.Background>
                                        <TextBlock Text="{Binding UserTier}"
                                                   FontSize="10" FontWeight="SemiBold">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{Binding TierAccentColor}"/>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Border>
                                    <TextBlock Text="{Binding UserMenuArrow}" FontSize="10"
                                               Foreground="{StaticResource BrushTextMuted}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Popup меню пользователя -->
                            <Popup x:Name="UserPopup"
                                   IsOpen="{Binding IsUserMenuOpen, Mode=TwoWay}"
                                   IsLightDismissEnabled="True"
                                   OverlayDismissEventPassThrough="True"
                                   ShouldUseOverlayLayer="True"
                                   Topmost="True"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=UserMenuBtn}"
                                   HorizontalOffset="-80">
                                <Border x:Name="UserPopupRoot"
                                        Background="{StaticResource BrushBgCard}"
                                        BorderBrush="{StaticResource BrushBorder}"
                                        BorderThickness="1" CornerRadius="12"
                                        Padding="8" MinWidth="200"
                                        BoxShadow="0 8 32 0 #000000CC">
                                    <StackPanel Spacing="2">
                                        <Border Padding="12,10">
                                            <StackPanel Spacing="3">
                                                <TextBlock Text="{Binding Username}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource BrushTextPrimary}"/>
                                                <TextBlock Text="{Binding UserTierFull}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource BrushTextSecondary}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Height="1" Background="{StaticResource BrushBorder}" Margin="8,2"/>
                                        <Button Content="👤  Профиль"
                                                Theme="{StaticResource MenuButton}" FontSize="13"
                                                Foreground="{StaticResource BrushTextSecondary}"/>
                                        <Button Content="🔑  Сменить аккаунт"
                                                Theme="{StaticResource MenuButton}" FontSize="13"
                                                Foreground="{StaticResource BrushTextSecondary}"/>
                                        <Border Height="1" Background="{StaticResource BrushBorder}" Margin="8,2"/>
                                        <Button Content="🚪  Выйти"
                                                Theme="{StaticResource MenuButton}" FontSize="13"
                                                Foreground="#FF5566"
                                                Command="{Binding LogoutCommand}"/>
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <Border Width="1" Height="20"
                                    Background="{StaticResource BrushBorder}" Margin="4,0"/>

                            <!-- Свернуть -->
                            <Border Classes="WinBtn"
                                    PointerPressed="MinimizeBtn_PointerPressed">
                                <TextBlock Text="—" FontSize="14"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Закрыть -->
                            <Border Classes="WinBtnClose"
                                    PointerPressed="CloseBtn_PointerPressed">
                                <TextBlock Text="✕" FontSize="13" Foreground="#FF5566"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ВКЛАДКИ -->
                <Border Grid.Row="1"
                        Background="{StaticResource BrushBgSurface}"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="0,0,0,1"
                        IsVisible="{Binding HasSubTabs}"
                        Padding="16,0">
                    <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">

                        <Border Classes="TabBtn"
                                PointerPressed="SubTab_PointerPressed" Tag="1">
                            <Panel>
                                <Border Height="2" CornerRadius="1"
                                        VerticalAlignment="Bottom" Margin="0,0,0,-6"
                                        IsVisible="{Binding IsSubTab1Active}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                            <GradientStop Offset="0" Color="#9B59FF"/>
                                            <GradientStop Offset="1" Color="#E040C8"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="{Binding SubTab1Title}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#F0F0F8" IsVisible="{Binding IsSubTab1Active}"/>
                                <TextBlock Text="{Binding SubTab1Title}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#555568" IsVisible="{Binding !IsSubTab1Active}"/>
                            </Panel>
                        </Border>

                        <Border Classes="TabBtn"
                                PointerPressed="SubTab_PointerPressed" Tag="2">
                            <Panel>
                                <Border Height="2" CornerRadius="1"
                                        VerticalAlignment="Bottom" Margin="0,0,0,-6"
                                        IsVisible="{Binding IsSubTab2Active}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                            <GradientStop Offset="0" Color="#9B59FF"/>
                                            <GradientStop Offset="1" Color="#E040C8"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="{Binding SubTab2Title}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#F0F0F8" IsVisible="{Binding IsSubTab2Active}"/>
                                <TextBlock Text="{Binding SubTab2Title}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#555568" IsVisible="{Binding !IsSubTab2Active}"/>
                            </Panel>
                        </Border>

                        <Border Classes="TabBtn"
                                PointerPressed="SubTab_PointerPressed" Tag="3"
                                IsVisible="{Binding HasSubTab3}">
                            <Panel>
                                <Border Height="2" CornerRadius="1"
                                        VerticalAlignment="Bottom" Margin="0,0,0,-6"
                                        IsVisible="{Binding IsSubTab3Active}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                            <GradientStop Offset="0" Color="#9B59FF"/>
                                            <GradientStop Offset="1" Color="#E040C8"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="{Binding SubTab3Title}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#F0F0F8" IsVisible="{Binding IsSubTab3Active}"/>
                                <TextBlock Text="{Binding SubTab3Title}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#555568" IsVisible="{Binding !IsSubTab3Active}"/>
                            </Panel>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- КОНТЕНТ -->
                <ContentControl Grid.Row="2"
                                Content="{Binding CurrentPage}"
                                Background="{StaticResource BrushBgBase}"/>

            </Grid>
        </Grid>
    </Border>
</Window>
