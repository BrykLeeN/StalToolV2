<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:StalTool.Models"
             x:Class="StalTool.Views.Controls.RadarWatchItemCard"
             x:DataType="models:AuctionRadarWatchItem">
    <Border Background="#101019"
            BorderBrush="#2A2A3A"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            Margin="0,0,0,8">
        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
            <TextBlock Text="{Binding ItemName}" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="1" Text="{Binding CurrentPriceText}" Foreground="#D5D8ED"/>
            <TextBlock Grid.Row="1" Text="{Binding TargetPriceText}" Foreground="#89A3FF" FontSize="11"/>

            <TextBlock Grid.Row="1"
                       Grid.Column="1"
                       Text="Активен"
                       Foreground="#44FF88"
                       FontSize="11"
                       IsVisible="{Binding IsActive}"/>
            <TextBlock Grid.Row="1"
                       Grid.Column="1"
                       Text="Не активен"
                       Foreground="#FF8A94"
                       FontSize="11"
                       IsVisible="{Binding !IsActive}"/>
        </Grid>
    </Border>
</UserControl>
