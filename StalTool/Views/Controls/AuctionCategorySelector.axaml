<UserControl
    x:Class="StalTool.Views.Controls.AuctionCategorySelector"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:StalTool.Converters"
    xmlns:models="using:StalTool.Models"
    x:Name="Root">
    <UserControl.Resources>
        <conv:IconPathToBitmapConverter x:Key="IconPathToBitmapConverter"/>
        <conv:RankToBrushConverter x:Key="RankToBrushConverter"/>
        <conv:RankToLabelConverter x:Key="RankToLabelConverter"/>
        <conv:StringNotEmptyToBoolConverter x:Key="StringNotEmptyToBoolConverter"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*"
          RowSpacing="10">
        <TextBlock Grid.Row="0"
                   Text="Категории"
                   Foreground="{DynamicResource BrushTextPrimary}"
                   FontSize="18"
                   FontWeight="SemiBold"/>

        <Border Grid.Row="1"
                Classes="AuctionCategorySearchFrame">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="6">
                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, ElementName=Root, Mode=TwoWay}"
                         Watermark="Поиск предмета..."
                         Classes="AuctionCategorySearchInner"/>
                <Button Grid.Column="1"
                        Classes="AuctionSearchClearBtn"
                        Command="{Binding ClearSearchCommand, ElementName=Root}"
                        IsVisible="{Binding SearchText, ElementName=Root, Converter={StaticResource StringNotEmptyToBoolConverter}}"
                        Margin="0,0,6,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="×"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,-1,0,0"/>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2"
                      Padding="0,0,6,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Categories, ElementName=Root}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:AuctionCategoryGroup">
                        <StackPanel Margin="0,0,0,10"
                                    Spacing="8">
                            <ToggleButton Classes="CategoryToggle"
                                          Classes.HasSelectedItem="{Binding HasSelectedItem}"
                                          IsChecked="{Binding IsExpanded}"
                                          Focusable="False">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      ColumnSpacing="8">
                                    <Border Width="8"
                                            Height="8"
                                            CornerRadius="8"
                                            Background="{DynamicResource BrushAppAccent}"
                                            IsVisible="{Binding ShowCollapsedSelectedIndicator}"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding CategoryName}"
                                               Classes="CategoryTitle"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Classes="CategoryArrow"
                                               Text="▸"
                                               Foreground="{DynamicResource BrushTextPrimary}"
                                               FontSize="18"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </ToggleButton>

                            <ItemsControl ItemsSource="{Binding FilteredItems}"
                                          Margin="8,0,8,0"
                                          IsVisible="{Binding IsExpanded}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:AuctionCatalogItem">
                                        <StackPanel Spacing="6">
                                            <Button Classes="CategoryItemBtn"
                                                    Classes.SelectedItem="{Binding IsSelected}"
                                                    Command="{Binding ToggleOrSelectItemCommand, ElementName=Root}"
                                                    CommandParameter="{Binding .}"
                                                    PointerPressed="OnCategoryItemPointerPressed"
                                                    HorizontalContentAlignment="Stretch">
                                                <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                                      ColumnSpacing="8">
                                                    <Border Width="26"
                                                            Height="26"
                                                            CornerRadius="8"
                                                            Background="#1F1635"
                                                            BorderBrush="#5A3D99"
                                                            BorderThickness="1"
                                                            VerticalAlignment="Center">
                                                        <Image Source="{Binding IconPath, Converter={StaticResource IconPathToBitmapConverter}}"
                                                               Stretch="UniformToFill"
                                                               Width="20"
                                                               Height="20"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding DisplayName}"
                                                               Foreground="{DynamicResource BrushTextPrimary}"
                                                               FontSize="13"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Border Grid.Column="2"
                                                            IsVisible="{Binding Rank, Converter={StaticResource StringNotEmptyToBoolConverter}}"
                                                            Background="{Binding Rank, Converter={StaticResource RankToBrushConverter}, ConverterParameter=background}"
                                                            BorderBrush="{Binding Rank, Converter={StaticResource RankToBrushConverter}, ConverterParameter=border}"
                                                            BorderThickness="1"
                                                            CornerRadius="8"
                                                            Padding="7,2"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Rank, Converter={StaticResource RankToLabelConverter}}"
                                                                   Foreground="{Binding Rank, Converter={StaticResource RankToBrushConverter}}"
                                                                   FontSize="10"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="3"
                                                               Text="⌄"
                                                               IsVisible="{Binding HasQualityVariants}"
                                                               Foreground="{DynamicResource BrushTextSecondary}"
                                                               FontSize="14"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Button>

                                            <ItemsControl ItemsSource="{Binding VisibleQualityVariants}"
                                                          Margin="14,0,0,4"
                                                          IsVisible="{Binding IsExpanded}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:AuctionCatalogItem">
                                                        <Button Classes="CategoryItemBtn"
                                                                Classes.SelectedItem="{Binding IsSelected}"
                                                                Command="{Binding SelectItemCommand, ElementName=Root}"
                                                                CommandParameter="{Binding .}"
                                                                PointerPressed="OnCategoryItemPointerPressed"
                                                                Margin="0,0,0,6"
                                                                HorizontalContentAlignment="Stretch">
                                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                                  ColumnSpacing="8">
                                                                <Border Width="22"
                                                                        Height="22"
                                                                        CornerRadius="7"
                                                                        Background="#1F1635"
                                                                        BorderBrush="#5A3D99"
                                                                        BorderThickness="1"
                                                                        VerticalAlignment="Center">
                                                                    <Image Source="{Binding IconPath, Converter={StaticResource IconPathToBitmapConverter}}"
                                                                           Stretch="UniformToFill"
                                                                           Width="16"
                                                                           Height="16"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding DisplayName}"
                                                                           Foreground="{DynamicResource BrushTextPrimary}"
                                                                           FontSize="12"
                                                                           VerticalAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <Border Grid.Column="2"
                                                                        Background="{Binding Rank, Converter={StaticResource RankToBrushConverter}, ConverterParameter=background}"
                                                                        BorderBrush="{Binding Rank, Converter={StaticResource RankToBrushConverter}, ConverterParameter=border}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8"
                                                                        Padding="7,2"
                                                                        VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Rank, Converter={StaticResource RankToLabelConverter}}"
                                                                               Foreground="{Binding Rank, Converter={StaticResource RankToBrushConverter}}"
                                                                               FontSize="10"/>
                                                                </Border>
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
