<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:StalTool.Models"
             x:Class="StalTool.Views.Controls.RadarSettingItemCard"
             x:DataType="models:AuctionRadarSettingItem">
    <Border Background="#101019"
            BorderBrush="#2A2A3A"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            Margin="0,0,0,8">
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="{Binding Name}" Foreground="#C8CCE2"/>
            <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="#9EA3BD"/>
        </Grid>
    </Border>
</UserControl>
